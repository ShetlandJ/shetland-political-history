---
import Base from '../../layouts/Base.astro';
import ExternalLink from '../../components/ExternalLink.astro';
import { getAllElections, getElectionById, getElectionsByPage, getCandidaciesForElection, getElectionNavigation } from '../../lib/db';

export function getStaticPaths() {
  const elections = getAllElections();
  // Only generate pages for the first election of each wiki_page_title group
  const seen = new Set<string>();
  const paths: { params: { id: string } }[] = [];
  for (const e of elections) {
    if (!seen.has(e.wiki_page_title)) {
      seen.add(e.wiki_page_title);
      paths.push({ params: { id: String(e.id) } });
    }
  }
  return paths;
}

const { id } = Astro.params;
const election = getElectionById(Number(id));
if (!election) return Astro.redirect('/');

// Get all elections on this page (for multi-constituency elections)
const pageElections = getElectionsByPage(election.wiki_page_title);

// Get prev/next election for navigation
const nav = getElectionNavigation(election.council_id, election.wiki_page_title, election.election_type);

// Build election page ID lookup for linkifying notes
const allElectionsForLinks = getAllElections();
const electionPageIdMap = new Map<string, number>();
for (const el of allElectionsForLinks) {
  const key = el.wiki_page_title.replace(/_/g, ' ');
  if (!electionPageIdMap.has(key)) electionPageIdMap.set(key, el.id);
  // Also store with underscores
  if (!electionPageIdMap.has(el.wiki_page_title)) electionPageIdMap.set(el.wiki_page_title, el.id);
}

function findElectionByFuzzyName(refName: string): number | null {
  // Try exact match first
  const exact = electionPageIdMap.get(refName) || electionPageIdMap.get(refName.replace(/ /g, '_'));
  if (exact) return exact;

  // Fuzzy: extract constituency name and year, find matching by-election
  // Handles: "Fetlar County Council By-Election May 1890" or "1890 Walls County Council by-election"
  let place: string | null = null;
  let year: string | null = null;
  const fmtA = refName.match(/^(\d{4})\s+(.+?)\s+(?:County Council\s+)?[Bb]y-[Ee]lection/);
  const fmtB = refName.match(/^(.+?)\s+(?:County Council\s+)?[Bb]y-[Ee]lection\s+(?:\w+\s+)?(\d{4})/);
  if (fmtA) { year = fmtA[1]; place = fmtA[2]; }
  else if (fmtB) { place = fmtB[1]; year = fmtB[2]; }
  if (place && year) {
    for (const [title, id] of electionPageIdMap) {
      if (title.toLowerCase().includes(place.toLowerCase()) &&
          title.toLowerCase().includes('by-election') &&
          title.includes(year)) {
        return id;
      }
    }
    // Try without year match (different month in title)
    for (const [title, id] of electionPageIdMap) {
      if (title.toLowerCase().includes(place.toLowerCase()) &&
          title.toLowerCase().includes('by-election') &&
          title.match(/\d{4}/)?.[0] === year) {
        return id;
      }
    }
  }
  return null;
}

function linkifyNotes(notes: string): { text: string; url: string | null }[] {
  const parts: { text: string; url: string | null }[] = [];
  // Match "see <election reference>" — reference can start with uppercase, digit, or lowercase
  const regex = /see\s+((?:[A-Z0-9]|\d{4}\s+\w)[^.]*?[Bb]y-[Ee]lection[^.]*)/g;
  let lastIdx = 0;
  let match;
  while ((match = regex.exec(notes)) !== null) {
    if (match.index > lastIdx) {
      parts.push({ text: notes.substring(lastIdx, match.index) + 'see ', url: null });
    } else {
      parts.push({ text: 'see ', url: null });
    }
    const refName = match[1].trim().replace(/\.$/, '');
    const elId = findElectionByFuzzyName(refName);
    parts.push({ text: refName, url: elId ? `/election/${elId}` : null });
    lastIdx = match.index + match[0].length;
  }
  if (lastIdx < notes.length) {
    parts.push({ text: notes.substring(lastIdx), url: null });
  }
  if (parts.length === 0) {
    parts.push({ text: notes, url: null });
  }
  return parts;
}

function electionYear(date: string | null): string {
  if (!date) return '?';
  return date.substring(0, 4);
}

function formatDate(d: string | null): string {
  if (!d) return 'Date unknown';
  const date = new Date(d);
  return date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
}

function parseExternalLink(name: string): { url: string; display: string } | null {
  const m = name.match(/^\[?(https?:\/\/[^\s\]]+)\s+([^\]]+)\]?$/);
  if (m) return { url: m[1], display: m[2].trim() };
  // Handle "Rev. [url name]" style prefix
  const m2 = name.match(/^(.+?)\s*\[(https?:\/\/[^\s\]]+)\s+([^\]]+)\]$/);
  if (m2) return { url: m2[2], display: `${m2[1].trim()} ${m2[3].trim()}` };
  return null;
}

function electionTitle(wpt: string): string {
  return wpt.replace(/_/g, ' ');
}
---
<Base title={electionTitle(election.wiki_page_title)}>
  <div class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href={`/council/${election.council_slug}`}>{election.council_name}</a> &rsaquo;
    Election
  </div>

  <h1>{electionTitle(election.wiki_page_title)}</h1>
  <p class="meta">
    {formatDate(election.election_date)}
    &middot;
    <span class={`badge badge-${election.election_type}`}>{election.election_type}</span>
  </p>

  {pageElections.map(e => {
    const candidacies = getCandidaciesForElection(e.id);
    return (
      <div>
        {e.constituency_name && <h2>
          {e.constituency_slug
            ? <a href={`/constituency/${e.constituency_slug}`}>{(e as any).constituency_display_name || e.constituency_name}</a>
            : ((e as any).constituency_display_name || e.constituency_name)}
          {(e as any).constituency_display_name && <span class="meta" style="font-size: 0.75rem; margin-left: 0.5rem; font-family: var(--font-body);">now {e.constituency_name}</span>}
        </h2>}

        {(e.electorate || e.turnout) && (
          <p class="meta">
            {e.electorate && <>Electorate: {e.electorate.toLocaleString()}{(e as any).electorate_detail && <> ({(e as any).electorate_detail})</>}</>}
            {e.electorate && e.turnout && <> &middot; </>}
            {e.turnout && <>Turnout: {e.turnout.toLocaleString()}{e.turnout_pct && <> ({e.turnout_pct}%)</>}</>}
          </p>
        )}

        {e.notes && (
          <p class="meta">
            {linkifyNotes(e.notes).map(part =>
              part.url ? <a href={part.url}>{part.text}</a> : part.text
            )}
          </p>
        )}

        {candidacies.length > 0 && (
          <table>
            <thead>
              <tr>
                <th>Candidate</th>
                {candidacies.some(c => c.party) && <th>Party</th>}
                <th>Votes</th>
                <th>Result</th>
              </tr>
            </thead>
            <tbody>
              {candidacies.map(c => (
                <tr>
                  <td>
                    {c.person_slug
                      ? <a href={`/person/${c.person_slug}`}>{c.candidate_name}</a>
                      : (() => {
                          const ext = parseExternalLink(c.candidate_name);
                          return ext
                            ? <ExternalLink href={ext.url} label={ext.display} />
                            : c.candidate_name;
                        })()}
                  </td>
                  {candidacies.some(c => c.party) && <td>{c.party || ''}</td>}
                  <td>{c.votes?.toLocaleString() || c.votes_text || ''}</td>
                  <td>
                    {c.elected
                      ? <span class="elected">Elected{c.role ? ` (${c.role})` : ''}</span>
                      : <span class="not-elected">Not elected</span>}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>
    );
  })}

  <div class="election-nav">
    <div class="election-nav-header">
      {election.election_type === 'by-election' ? 'By-elections' : 'Elections'}
    </div>
    <div class="election-nav-row">
      <div class="election-nav-cell">
        {nav.prev ? (
          <a href={`/election/${nav.prev.min_id}`}>&lt; {electionYear(nav.prev.election_date)}{nav.prev.election_type === 'by-election' ? ' (by)' : ''}</a>
        ) : (
          <span class="muted">&mdash;</span>
        )}
      </div>
      <div class="election-nav-cell election-nav-current">
        <strong>{electionYear(election.election_date)}</strong>
      </div>
      <div class="election-nav-cell">
        {nav.next ? (
          <a href={`/election/${nav.next.min_id}`}>{electionYear(nav.next.election_date)}{nav.next.election_type === 'by-election' ? ' (by)' : ''} &gt;</a>
        ) : (
          <span class="muted">&mdash;</span>
        )}
      </div>
    </div>
    {election.election_type === 'by-election' && (nav.prevGeneral || nav.nextGeneral) && (
      <div class="election-nav-generals">
        {nav.prevGeneral && (
          <a href={`/election/${nav.prevGeneral.min_id}`}>&lt; {electionYear(nav.prevGeneral.election_date)} general</a>
        )}
        {nav.prevGeneral && nav.nextGeneral && <span class="muted">&middot;</span>}
        {nav.nextGeneral && (
          <a href={`/election/${nav.nextGeneral.min_id}`}>{electionYear(nav.nextGeneral.election_date)} general &gt;</a>
        )}
      </div>
    )}
  </div>
</Base>

<style>
  .election-nav {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin: 2.5rem 0;
    max-width: 360px;
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }

  .election-nav-header {
    background: var(--table-header-bg);
    color: var(--table-header-text);
    text-align: center;
    padding: 0.55rem;
    font-weight: 600;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-family: var(--font-body);
  }

  .election-nav-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
  }

  .election-nav-cell {
    padding: 0.7rem;
    text-align: center;
    border-right: 1px solid var(--border-light);
    font-variant-numeric: tabular-nums;
  }

  .election-nav-cell:last-child {
    border-right: none;
  }

  .election-nav-current {
    font-size: 1.1rem;
    font-family: var(--font-display);
    background: var(--accent-light);
  }

  .muted {
    color: var(--muted);
  }

  .election-nav-generals {
    border-top: 1px solid var(--border-light);
    padding: 0.5rem 0.7rem;
    text-align: center;
    font-size: 0.82rem;
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    align-items: center;
  }
</style>
