---
import Base from '../../layouts/Base.astro';
import ExternalLink from '../../components/ExternalLink.astro';
import { getAllPeople, getPersonBySlug, getCandidaciesForPerson, getAllElections, getTenuresForPerson, getLeadershipRolesForPerson, getLeadershipSuccessionForPerson, getConstituencyMembers, getConstituencyIdBySlug, getRelatedPeople } from '../../lib/db';
import fs from 'fs';
import path from 'path';

export function getStaticPaths() {
  const people = getAllPeople();
  return people.map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const person = getPersonBySlug(slug!);
if (!person) return Astro.redirect('/');

const candidacies = getCandidaciesForPerson(person.id);
const tenures = getTenuresForPerson(person.id);
const leadershipRoles = getLeadershipRolesForPerson(person.id);

// Build election page ID lookup: wiki_page_title -> first election id
const allElections = getAllElections();
const pageIdMap = new Map<string, number>();
for (const e of allElections) {
  if (!pageIdMap.has(e.wiki_page_title)) {
    pageIdMap.set(e.wiki_page_title, e.id);
  }
}

function formatDate(d: string | null): string {
  if (!d) return '';
  // Handle qualifiers: "abt 1776", "bef 1790", "aft 1800"
  const qualMatch = d.match(/^(abt|bef|aft)\s+(.+)$/i);
  if (qualMatch) {
    const qualMap: Record<string, string> = { abt: 'c.', bef: 'bef.', aft: 'aft.' };
    const qual = qualMap[qualMatch[1].toLowerCase()] || qualMatch[1];
    return `${qual} ${formatDate(qualMatch[2])}`;
  }
  if (/^\d{4}$/.test(d)) return d; // year only
  const parts = d.split('-');
  if (parts.length === 3) {
    const date = new Date(d);
    return date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
  }
  return d;
}

function formatYear(d: string | null): string {
  if (!d) return '?';
  return d.substring(0, 4);
}

function lifespan(person: any): string {
  const parts: string[] = [];
  if (person.born_date) {
    let born = `b. ${formatDate(person.born_date)}`;
    if (person.birth_place) born += `, ${person.birth_place}`;
    parts.push(born);
  }
  if (person.died_date) {
    let died = `d. ${formatDate(person.died_date)}`;
    if (person.death_place) died += `, ${person.death_place}`;
    parts.push(died);
  }
  return parts.join(' | ');
}

// Check for person photo
const imageExts = ['.jpg', '.jpeg', '.png', '.gif'];

function findPersonImage(personSlug: string): string | null {
  for (const ext of imageExts) {
    const imgPath = path.join(process.cwd(), 'public', 'images', 'people', personSlug + ext);
    if (fs.existsSync(imgPath)) {
      return `/images/people/${personSlug}${ext}`;
    }
  }
  return null;
}

const personImage = findPersonImage(slug!);

// Resolve predecessor/successor headshot images for tenure boxes
// Prefer headshot files (slug + "-headshot"), fall back to main photo
function findPersonHeadshot(personSlug: string): string | null {
  // First try headshot-specific file
  for (const ext of imageExts) {
    const imgPath = path.join(process.cwd(), 'public', 'images', 'people', personSlug + '-headshot' + ext);
    if (fs.existsSync(imgPath)) {
      return `/images/people/${personSlug}-headshot${ext}`;
    }
  }
  // Fall back to main image
  return findPersonImage(personSlug);
}

for (const t of tenures) {
  t.predecessor_image = t.predecessor_slug ? findPersonHeadshot(t.predecessor_slug) : null;
  t.successor_image = t.successor_slug ? findPersonHeadshot(t.successor_slug) : null;
}

// Leadership succession (Provost/Convener prev/next + full list)
const leadershipSuccession = getLeadershipSuccessionForPerson(person.id);

// Constituency member lists for each tenure
const constituencyMemberLists = new Map<string, { name: string; slug: string | null; start_year: string; end_year: string }[]>();
for (const t of tenures) {
  if (!constituencyMemberLists.has(t.constituency_slug)) {
    const cId = getConstituencyIdBySlug(t.constituency_slug);
    if (cId) {
      constituencyMemberLists.set(t.constituency_slug, getConstituencyMembers(cId));
    }
  }
}

const relatedPeople = getRelatedPeople(slug!);

// Build description for SEO
const descParts: string[] = [];
if (candidacies.length > 0) {
  const councils = [...new Set(candidacies.map(c => c.council_name))];
  descParts.push(councils.join(', '));
}
if (person.born_date) descParts.push(`born ${formatDate(person.born_date)}`);
const personDesc = descParts.length > 0 ? `${person.name} - ${descParts.join('. ')}.` : `${person.name} - Shetland politician.`;

// JSON-LD structured data
const jsonLd: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: person.name,
};
if (person.born_date) jsonLd.birthDate = person.born_date;
if (person.died_date) jsonLd.deathDate = person.died_date;
if (person.birth_place) jsonLd.birthPlace = { '@type': 'Place', name: person.birth_place };
if (person.death_place) jsonLd.deathPlace = { '@type': 'Place', name: person.death_place };
if (person.intro) jsonLd.description = person.intro.replace(/\[person:[^\]]+:([^\]]+)\]/g, '$1').substring(0, 200);

/** Convert [person:slug:Display] markers to HTML links, escaping other HTML */
function renderLinkedText(text: string): string {
  // First escape HTML entities in the raw text
  const escaped = text
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
  // Then convert person link markers to anchor tags
  return escaped.replace(
    /\[person:([^\]:]+):([^\]]+)\]/g,
    '<a href="/person/$1">$2</a>'
  ).replace(/&lt;strong&gt;/g, '<strong>')
   .replace(/&lt;\/strong&gt;/g, '</strong>');
}
---
<Base title={person.name} description={personDesc} ogType="profile" jsonLd={jsonLd}>
  <div class="breadcrumb"><a href="/">Home</a> &rsaquo; <a href="/people">People</a> &rsaquo; {person.name}</div>

  <h1>{person.name}</h1>

  <div class="person-body">
    <div class="infobox">
      {personImage && (
        <div class="infobox-photo">
          <img src={personImage} alt={person.name} width="260" height="260" loading="lazy" />
        </div>
      )}
      <table class="infobox-table">
        {person.born_date && (
          <tr>
            <th scope="row">Born</th>
            <td>{formatDate(person.born_date)}{person.birth_place ? `, ${person.birth_place}` : ''}</td>
          </tr>
        )}
        {person.died_date && (
          <tr>
            <th scope="row">Died</th>
            <td>{formatDate(person.died_date)}{person.death_place ? `, ${person.death_place}` : ''}</td>
          </tr>
        )}
        {leadershipRoles.length > 0 && leadershipRoles.map(r => (
          <tr>
            <th scope="row">{r.role}</th>
            <td><a href={`/council/${r.council_slug}`}>{r.council_name}</a><br />{r.start_year}–{r.end_year}</td>
          </tr>
        ))}
        {candidacies.length > 0 && (
          <tr>
            <th scope="row">Elections</th>
            <td>{candidacies.length} ({candidacies.filter(c => c.elected).length} won)</td>
          </tr>
        )}
        {person.bayanne_id && (
          <tr>
            <th scope="row">Bayanne</th>
            <td><a href={`http://www.bayanne.info/Shetland/getperson.php?personID=${person.bayanne_id}&tree=ID1`} target="_blank" rel="noopener">Genealogy page</a></td>
          </tr>
        )}
        {person.findagrave_id && (
          <tr>
            <th scope="row">Grave</th>
            <td><a href={`https://www.findagrave.com/memorial/${person.findagrave_id}`} target="_blank" rel="noopener">Find A Grave</a></td>
          </tr>
        )}
      </table>
    </div>

    {person.intro && (
      <div class="bio-text">
        {person.intro.split('\n\n').map(para => (
          <p set:html={renderLinkedText(para)} />
        ))}
      </div>
    )}

    {person.biography && (
      <div class="biography-section">
        <h2>Biography</h2>
        <div class="bio-text">
          {person.biography.split('\n\n').map(para => (
            <p set:html={renderLinkedText(para)} />
          ))}
        </div>
      </div>
    )}
  </div>

  <h2>Political Career</h2>
  {candidacies.length > 0 ? (
    <table>
      <caption class="sr-only">Political career of {person.name}</caption>
      <thead>
        <tr>
          <th scope="col">Year</th>
          <th scope="col">Election</th>
          <th scope="col">Council</th>
          <th scope="col">Votes</th>
          <th scope="col">Result</th>
        </tr>
      </thead>
      <tbody>
        {candidacies.map(c => {
          const electionPageId = pageIdMap.get(c.wiki_page_title);
          return (
            <tr>
              <td>{formatYear(c.election_date)}</td>
              <td>
                {electionPageId
                  ? <a href={`/election/${electionPageId}`}>
                      {c.wiki_page_title.replace(/_/g, ' ')}
                      {c.constituency_name && <> ({c.constituency_name})</>}
                    </a>
                  : <>{c.wiki_page_title.replace(/_/g, ' ')}</>}
              </td>
              <td><a href={`/council/${c.council_slug}`}>{c.council_name}</a></td>
              <td>{c.votes ? c.votes.toLocaleString() : ''}</td>
              <td>
                {c.elected
                  ? <span class="elected">{c.votes_text && !c.votes ? c.votes_text : `Elected${c.role ? ` (${c.role})` : ''}`}</span>
                  : <span class="not-elected">{c.votes_text || 'Not elected'}</span>}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  ) : (
    <p class="meta">No election records found for this person.</p>
  )}

  {tenures.length > 0 && (
    <>
      <h2>Offices Held</h2>
      {tenures.map((t, i) => {
        const prevCouncil = i > 0 ? tenures[i - 1].council_name : null;
        const sameCouncil = t.council_name === prevCouncil;
        return (
        <div class={`succession-box ${sameCouncil ? 'succession-continued' : ''}`}>
          {!sameCouncil && <div class="succession-header">{t.council_name}</div>}
          <div class="succession-row">
            <div class="succession-cell">
              {t.predecessor_name
                ? <>
                    Preceded by<br />
                    {t.predecessor_image && (
                      <a href={t.predecessor_slug ? `/person/${t.predecessor_slug}` : '#'}>
                        <img src={t.predecessor_image} alt={t.predecessor_name} class="succession-thumb" width="40" height="40" loading="lazy" />
                      </a>
                    )}
                    {t.predecessor_slug
                      ? <a href={`/person/${t.predecessor_slug}`}><strong>{t.predecessor_name}</strong></a>
                      : <strong>{t.predecessor_name}</strong>}
                  </>
                : <em>Constituency created</em>}
            </div>
            <div class="succession-cell succession-main">
              <div>
                <strong>Member for<br />
                <a href={`/constituency/${t.constituency_slug}`}>{t.constituency_name}</a></strong><br />
                {t.start_year}&ndash;{t.end_year}
              </div>
            </div>
            <div class="succession-cell">
              {t.successor_name
                ? <>
                    Succeeded by<br />
                    {t.successor_image && (
                      <a href={t.successor_slug ? `/person/${t.successor_slug}` : '#'}>
                        <img src={t.successor_image} alt={t.successor_name} class="succession-thumb" width="40" height="40" loading="lazy" />
                      </a>
                    )}
                    {t.successor_slug
                      ? <a href={`/person/${t.successor_slug}`}><strong>{t.successor_name}</strong></a>
                      : <strong>{t.successor_name}</strong>}
                  </>
                : <em>Incumbent / seat abolished</em>}
            </div>
          </div>
        </div>
        );
      })}
    </>
  )}

  {leadershipSuccession.length > 0 && leadershipSuccession.map(ls => {
    const predImage = ls.predecessor?.slug ? findPersonHeadshot(ls.predecessor.slug) : null;
    const succImage = ls.successor?.slug ? findPersonHeadshot(ls.successor.slug) : null;
    return (
    <div class="succession-box" style="margin-top: 1.5rem;">
      <div class="succession-header">{ls.role}s</div>
      <div class="succession-row">
        <div class="succession-cell">
          {ls.predecessor
            ? <>
                Preceded by<br />
                {predImage && ls.predecessor.slug && (
                  <a href={`/person/${ls.predecessor.slug}`}>
                    <img src={predImage} alt={ls.predecessor.name} class="succession-thumb" width="40" height="40" loading="lazy" />
                  </a>
                )}
                {ls.predecessor.slug
                  ? <a href={`/person/${ls.predecessor.slug}`}><strong>{ls.predecessor.name}</strong></a>
                  : <strong>{ls.predecessor.name}</strong>}
              </>
            : <em>New position</em>}
        </div>
        <div class="succession-cell succession-main">
          <div>
            <strong>{ls.role}<br />
            for <a href={`/council/${ls.council_slug}`}>{ls.council_name}</a></strong><br />
            {ls.start_year}&ndash;{ls.end_year}
          </div>
        </div>
        <div class="succession-cell">
          {ls.successor
            ? <>
                Succeeded by<br />
                {succImage && ls.successor.slug && (
                  <a href={`/person/${ls.successor.slug}`}>
                    <img src={succImage} alt={ls.successor.name} class="succession-thumb" width="40" height="40" loading="lazy" />
                  </a>
                )}
                {ls.successor.slug
                  ? <a href={`/person/${ls.successor.slug}`}><strong>{ls.successor.name}</strong></a>
                  : <strong>{ls.successor.name}</strong>}
              </>
            : <em>Last holder</em>}
        </div>
      </div>
    </div>
    <details class="nav-list-box">
      <summary class="nav-list-header">
        {ls.role}s of the {ls.council_name}
      </summary>
      <div class="nav-list-body">
        {ls.allLeaders.map((l, i) => (
          <>{i > 0 && <span class="nav-list-sep"> &middot; </span>}{l.isCurrent
            ? <strong>{l.name}</strong>
            : l.slug
              ? <a href={`/person/${l.slug}`}>{l.name}</a>
              : l.name} <span class="nav-list-years"> ({l.start_year}&ndash;{l.end_year})</span></>
        ))}
      </div>
    </details>
    );
  })}

  {tenures.length > 0 && [...constituencyMemberLists.entries()].map(([conSlug, members]) => {
    const tenure = tenures.find(t => t.constituency_slug === conSlug);
    if (!tenure || members.length < 2) return null;
    return (
      <details class="nav-list-box">
        <summary class="nav-list-header">
          {tenure.constituency_name} Members
        </summary>
        <div class="nav-list-body">
          {members.map((m, i) => {
            const isCurrent = m.slug === slug;
            return (
              <>{i > 0 && <span class="nav-list-sep"> &middot; </span>}{isCurrent
                ? <strong>{m.name}</strong>
                : m.slug
                  ? <a href={`/person/${m.slug}`}>{m.name}</a>
                  : m.name} <span class="nav-list-years"> ({m.start_year}&ndash;{m.end_year})</span></>
            );
          })}
        </div>
      </details>
    );
  })}

  {relatedPeople.length > 0 && (
    <div class="related-people">
      <h2>Related People</h2>
      <p class="related-list">
        {relatedPeople.map((rp, i) => (
          <>{i > 0 && <span class="related-sep"> · </span>}<a href={`/person/${rp.slug}`}>{rp.name}</a></>
        ))}
      </p>
    </div>
  )}

</Base>

<style>
  .person-body {
    overflow: hidden; /* contain the float */
  }

  .infobox {
    width: 260px;
    float: right;
    margin: 0 0 1rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-surface);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }

  .infobox-photo {
    width: 100%;
    background: var(--bg-surface-alt);
  }

  .infobox-photo img {
    width: 100%;
    height: auto;
    display: block;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  .infobox-table {
    width: 100%;
    margin: 0;
    border: none;
    box-shadow: none;
    border-radius: 0;
    font-size: 0.85rem;
  }

  .infobox-table th {
    background: var(--bg-surface-alt);
    font-weight: 600;
    width: 5.5rem;
    vertical-align: top;
    padding: 0.4rem 0.6rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  .infobox-table td {
    padding: 0.4rem 0.6rem;
    vertical-align: top;
  }

  .infobox-table tr:last-child td,
  .infobox-table tr:last-child th {
    border-bottom: none;
  }

  @media (max-width: 600px) {
    .person-body {
      display: flex;
      flex-direction: column;
    }

    .infobox {
      float: none;
      width: 100%;
      margin: 0 0 1rem 0;
      order: 1;
    }

    .bio-text:first-of-type {
      order: 0;
    }

    .biography-section {
      order: 2;
    }
  }

  .succession-box {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin: 1rem 0;
    max-width: 100%;
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }

  .succession-header {
    background: var(--accent-light);
    text-align: center;
    padding: 0.55rem;
    font-weight: 600;
    font-size: 0.88rem;
    color: var(--accent);
    border-bottom: 1px solid var(--border);
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .succession-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
  }

  .succession-cell {
    padding: 0.85rem 0.75rem;
    text-align: center;
    font-size: 0.88rem;
    border-right: 1px solid var(--border-light);
    line-height: 1.5;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .succession-cell:last-child {
    border-right: none;
  }

  .succession-main {
    background: var(--accent-light);
  }

  .succession-continued {
    margin-top: 0;
    border-top: none;
    border-top-left-radius: 0;
    border-top-right-radius: 0;
  }

  .succession-box:has(+ .succession-continued) {
    margin-bottom: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }

  .succession-thumb {
    width: 40px;
    height: 40px;
    object-fit: cover;
    border-radius: 50%;
    border: 1px solid var(--border);
    display: block;
    margin: 0.3rem auto;
  }

  @media (max-width: 600px) {
    .succession-row {
      grid-template-columns: 1fr;
    }
    .succession-cell {
      border-right: none;
      border-bottom: 1px solid var(--border-light);
    }
    .succession-cell:last-child {
      border-bottom: none;
    }
  }

  /* Collapsible nav list (leaders list, constituency members) */
  .nav-list-box {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin: 0.75rem 0;
    background: var(--bg-surface);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }

  .nav-list-header {
    background: var(--accent-light);
    padding: 0.55rem 0.85rem;
    font-weight: 600;
    font-size: 0.88rem;
    color: var(--accent);
    cursor: pointer;
    text-align: center;
    list-style: none;
    font-family: var(--font-body);
  }

  .nav-list-header::-webkit-details-marker {
    display: none;
  }

  .nav-list-header::before {
    content: "\25B8 ";
    font-size: 0.75rem;
    margin-right: 0.3rem;
  }

  details[open] > .nav-list-header::before {
    content: "\25BE ";
  }

  .nav-list-body {
    padding: 0.75rem 0.85rem;
    font-size: 0.85rem;
    line-height: 1.7;
  }

  .nav-list-sep {
    color: var(--muted);
  }

  .nav-list-years {
    color: var(--muted);
    font-size: 0.78rem;
  }

  .related-list {
    line-height: 1.8;
  }

  .related-sep {
    color: var(--muted);
  }
</style>
