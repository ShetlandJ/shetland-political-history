---
import Base from '../../layouts/Base.astro';
import ExternalLink from '../../components/ExternalLink.astro';
import { getAllPeople, getPersonBySlug, getCandidaciesForPerson, getAllElections, getTenuresForPerson, getLeadershipRolesForPerson } from '../../lib/db';
import fs from 'fs';
import path from 'path';

export function getStaticPaths() {
  const people = getAllPeople();
  return people.map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const person = getPersonBySlug(slug!);
if (!person) return Astro.redirect('/');

const candidacies = getCandidaciesForPerson(person.id);
const tenures = getTenuresForPerson(person.id);
const leadershipRoles = getLeadershipRolesForPerson(person.id);

// Build election page ID lookup: wiki_page_title -> first election id
const allElections = getAllElections();
const pageIdMap = new Map<string, number>();
for (const e of allElections) {
  if (!pageIdMap.has(e.wiki_page_title)) {
    pageIdMap.set(e.wiki_page_title, e.id);
  }
}

function formatDate(d: string | null): string {
  if (!d) return '';
  if (/^\d{4}$/.test(d)) return d; // year only
  const parts = d.split('-');
  if (parts.length === 3) {
    const date = new Date(d);
    return date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
  }
  return d;
}

function formatYear(d: string | null): string {
  if (!d) return '?';
  return d.substring(0, 4);
}

function lifespan(person: any): string {
  const parts: string[] = [];
  if (person.born_date) {
    let born = `b. ${formatDate(person.born_date)}`;
    if (person.birth_place) born += `, ${person.birth_place}`;
    parts.push(born);
  }
  if (person.died_date) {
    let died = `d. ${formatDate(person.died_date)}`;
    if (person.death_place) died += `, ${person.death_place}`;
    parts.push(died);
  }
  return parts.join(' | ');
}

// Check for person photo
const imageExts = ['.jpg', '.jpeg', '.png', '.gif'];

function findPersonImage(personSlug: string): string | null {
  for (const ext of imageExts) {
    const imgPath = path.join(process.cwd(), 'public', 'images', 'people', personSlug + ext);
    if (fs.existsSync(imgPath)) {
      return `/images/people/${personSlug}${ext}`;
    }
  }
  return null;
}

const personImage = findPersonImage(slug!);

// Resolve predecessor/successor headshot images for tenure boxes
// Prefer headshot files (slug + "-headshot"), fall back to main photo
function findPersonHeadshot(personSlug: string): string | null {
  // First try headshot-specific file
  for (const ext of imageExts) {
    const imgPath = path.join(process.cwd(), 'public', 'images', 'people', personSlug + '-headshot' + ext);
    if (fs.existsSync(imgPath)) {
      return `/images/people/${personSlug}-headshot${ext}`;
    }
  }
  // Fall back to main image
  return findPersonImage(personSlug);
}

for (const t of tenures) {
  t.predecessor_image = t.predecessor_slug ? findPersonHeadshot(t.predecessor_slug) : null;
  t.successor_image = t.successor_slug ? findPersonHeadshot(t.successor_slug) : null;
}
---
<Base title={person.name}>
  <div class="breadcrumb"><a href="/">Home</a> &rsaquo; <a href="/people">People</a> &rsaquo; {person.name}</div>

  <h1>{person.name}</h1>

  {lifespan(person) && <p class="meta">{lifespan(person)}</p>}

  {leadershipRoles.length > 0 && (
    <p class="meta">
      {leadershipRoles.map((r, i) => (
        <>{i > 0 && ' · '}<strong>{r.role}</strong> of the <a href={`/council/${r.council_slug}`}>{r.council_name}</a> ({r.start_year}–{r.end_year})</>
      ))}
    </p>
  )}

  <div class={personImage ? 'person-header' : ''}>
    {personImage && (
      <div class="person-photo">
        <img src={personImage} alt={person.name} />
      </div>
    )}
    <div>
      {person.intro && (
        <div class="bio-text">
          {person.intro.split('\n\n').map(para => (
            <p>{para}</p>
          ))}
        </div>
      )}
    </div>
  </div>

  {person.biography && (
    <>
      <h2>Biography</h2>
      <div class="bio-text">
        {person.biography.split('\n\n').map(para => (
          <p>{para}</p>
        ))}
      </div>
    </>
  )}

  <h2>Political Career</h2>
  {candidacies.length > 0 ? (
    <table>
      <thead>
        <tr>
          <th>Year</th>
          <th>Election</th>
          <th>Council</th>
          <th>Votes</th>
          <th>Result</th>
        </tr>
      </thead>
      <tbody>
        {candidacies.map(c => {
          const electionPageId = pageIdMap.get(c.wiki_page_title);
          return (
            <tr>
              <td>{formatYear(c.election_date)}</td>
              <td>
                {electionPageId
                  ? <a href={`/election/${electionPageId}`}>
                      {c.wiki_page_title.replace(/_/g, ' ')}
                      {c.constituency_name && <> ({c.constituency_name})</>}
                    </a>
                  : <>{c.wiki_page_title.replace(/_/g, ' ')}</>}
              </td>
              <td><a href={`/council/${c.council_slug}`}>{c.council_name}</a></td>
              <td>{c.votes?.toLocaleString() || c.votes_text || ''}</td>
              <td>
                {c.elected
                  ? <span class="elected">Elected{c.role ? ` (${c.role})` : ''}</span>
                  : <span class="not-elected">Not elected</span>}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  ) : (
    <p class="meta">No election records found for this person.</p>
  )}

  {tenures.length > 0 && (
    <>
      <h2>Offices Held</h2>
      {tenures.map((t, i) => {
        const prevCouncil = i > 0 ? tenures[i - 1].council_name : null;
        const sameCouncil = t.council_name === prevCouncil;
        return (
        <div class={`succession-box ${sameCouncil ? 'succession-continued' : ''}`}>
          {!sameCouncil && <div class="succession-header">{t.council_name}</div>}
          <div class="succession-row">
            <div class="succession-cell">
              {t.predecessor_name
                ? <>
                    Preceded by<br />
                    {t.predecessor_image && (
                      <a href={t.predecessor_slug ? `/person/${t.predecessor_slug}` : '#'}>
                        <img src={t.predecessor_image} alt={t.predecessor_name} class="succession-thumb" />
                      </a>
                    )}
                    {t.predecessor_slug
                      ? <a href={`/person/${t.predecessor_slug}`}><strong>{t.predecessor_name}</strong></a>
                      : <strong>{t.predecessor_name}</strong>}
                  </>
                : <em>Constituency created</em>}
            </div>
            <div class="succession-cell succession-main">
              <strong>Member for<br />
              <a href={`/constituency/${t.constituency_slug}`}>{t.constituency_name}</a></strong><br />
              {t.start_year}&ndash;{t.end_year}
            </div>
            <div class="succession-cell">
              {t.successor_name
                ? <>
                    Succeeded by<br />
                    {t.successor_image && (
                      <a href={t.successor_slug ? `/person/${t.successor_slug}` : '#'}>
                        <img src={t.successor_image} alt={t.successor_name} class="succession-thumb" />
                      </a>
                    )}
                    {t.successor_slug
                      ? <a href={`/person/${t.successor_slug}`}><strong>{t.successor_name}</strong></a>
                      : <strong>{t.successor_name}</strong>}
                  </>
                : <em>Incumbent / seat abolished</em>}
            </div>
          </div>
        </div>
        );
      })}
    </>
  )}

  {person.bayanne_id && (
    <>
      <h2>External Links</h2>
      <ul>
        <li><ExternalLink href={`http://www.bayanne.info/Shetland/getperson.php?personID=${person.bayanne_id}&tree=ID1`} label="Bayanne genealogy page" /></li>
      </ul>
    </>
  )}
</Base>

<style>
  .person-header {
    display: flex;
    gap: 1.75rem;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }

  .person-photo {
    flex-shrink: 0;
  }

  .person-photo img {
    width: 170px;
    height: auto;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-md);
  }

  @media (max-width: 600px) {
    .person-header {
      flex-direction: column;
    }
    .person-photo img {
      width: 130px;
    }
  }

  .succession-box {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin: 1rem 0;
    max-width: 680px;
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }

  .succession-header {
    background: var(--accent-light);
    text-align: center;
    padding: 0.55rem;
    font-weight: 600;
    font-size: 0.88rem;
    color: var(--accent);
    border-bottom: 1px solid var(--border);
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .succession-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
  }

  .succession-cell {
    padding: 0.85rem 0.75rem;
    text-align: center;
    font-size: 0.88rem;
    border-right: 1px solid var(--border-light);
    line-height: 1.5;
  }

  .succession-cell:last-child {
    border-right: none;
  }

  .succession-main {
    background: var(--accent-light);
  }

  .succession-continued {
    margin-top: 0;
    border-top: none;
    border-top-left-radius: 0;
    border-top-right-radius: 0;
  }

  .succession-box:has(+ .succession-continued) {
    margin-bottom: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }

  .succession-thumb {
    width: 40px;
    height: 40px;
    object-fit: cover;
    border-radius: 50%;
    border: 1px solid var(--border);
    display: block;
    margin: 0.3rem auto;
  }

  @media (max-width: 600px) {
    .succession-row {
      grid-template-columns: 1fr;
    }
    .succession-cell {
      border-right: none;
      border-bottom: 1px solid var(--border-light);
    }
    .succession-cell:last-child {
      border-bottom: none;
    }
  }
</style>
