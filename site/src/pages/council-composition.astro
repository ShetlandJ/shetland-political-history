---
import Base from '../layouts/Base.astro';
import Database from 'better-sqlite3';
import path from 'path';

const db = new Database(path.join(process.cwd(), 'shetland.db'), { readonly: true });

const ltcCouncil = db.prepare("SELECT id FROM councils WHERE slug = 'lerwick-town-council'").get() as any;
const ltcId = ltcCouncil.id;

// Get all LTC elections in date order, including replaced person info
const elections = db.prepare(`
  SELECT e.id, e.wiki_page_title, e.election_date, e.election_type,
         e.replaced_person, e.replaced_person_id, e.notes,
         rp.name as replaced_person_name, rp.slug as replaced_person_slug
  FROM elections e
  LEFT JOIN people rp ON e.replaced_person_id = rp.id
  WHERE e.council_id = ? AND e.hidden = 0
  GROUP BY e.wiki_page_title
  ORDER BY e.election_date
`).all(ltcId) as any[];

// Get elected candidates per election
const electedByElection = new Map<string, any[]>();
for (const e of elections) {
  const cands = db.prepare(`
    SELECT c.candidate_name, c.person_id, c.role, c.votes_text,
           p.slug as person_slug, p.name as person_name
    FROM candidacies c
    JOIN elections e2 ON c.election_id = e2.id
    LEFT JOIN people p ON c.person_id = p.id
    WHERE e2.wiki_page_title = ? AND c.elected = 1 AND e2.hidden = 0
    ORDER BY c.position
  `).all(e.wiki_page_title) as any[];
  electedByElection.set(e.wiki_page_title, cands);
}

// Get provosts
const provosts = db.prepare(`
  SELECT person_name, person_id, start_year, end_year
  FROM leadership_roles
  WHERE council_id = ? AND role = 'Provost'
  ORDER BY start_year
`).all(ltcId) as any[];

interface Member {
  name: string;
  slug: string | null;
  fromByElection: boolean;
  diedDate: string | null;
}

// Build a death-date lookup for all people
const deathDates = new Map<string, string>();
const allPeople = db.prepare("SELECT name, died_date FROM people WHERE died_date IS NOT NULL").all() as any[];
for (const p of allPeople) {
  deathDates.set(p.name, p.died_date);
}

// Mid-term departures not recorded as by-elections in the wiki data.
// These are resignations/retirements confirmed from newspaper sources and person profiles.
const manualDepartures: { name: string; date: string }[] = [
  { name: 'Thomas Cameron', date: '1883-09-01' },       // Retired from council, confirmed in profile
  { name: 'William Duncan (i)', date: '1886-07-12' },   // Resigned, confirmed in profile
  { name: 'John Harrison (i)', date: '1886-10-01' },    // Disqualified, confirmed from newspaper 23 Oct 1886
  { name: 'Alexander Mitchell (i)', date: '1889-09-01' }, // Retired, confirmed from newspaper 26 Oct 1889
  { name: 'William MacDougall', date: '1912-04-01' },   // Resigned, confirmed in profile
  { name: 'William Sinclair', date: '1921-10-01' },     // Retired, confirmed from newspaper Nov 1921
];

// Helper: remove a person by name, handling disambiguations
// "William Sievwright" should match "William Sievwright (ii)"
function removePerson(list: Member[], name: string): Member[] {
  // Try exact match first
  const exact = list.filter(m => m.name !== name);
  if (exact.length < list.length) return exact;
  // Try matching without disambiguation suffix
  const cleanName = name.replace(/\s*\([^)]*\)\s*$/, '');
  return list.filter(m => {
    const mClean = m.name.replace(/\s*\([^)]*\)\s*$/, '');
    return mClean !== cleanName;
  });
}

interface Snapshot {
  wikiTitle: string;
  date: string;
  type: string;
  electionId: number;
  members: Member[];
  newMembers: Set<string>;
  provost: string | null;
  provostSlug: string | null;
}

const snapshots: Snapshot[] = [];

// Track cohorts with 3-year terms
// Each general election creates a cohort that expires 3 general elections later
// By-election winners expire at the NEXT general election
let cohorts: { wikiTitle: string; members: Member[]; expiresAfterGenerals: number }[] = [];
let byElectionMembers: Member[] = [];
let generalCount = 0;

for (const election of elections) {
  const elected = electedByElection.get(election.wiki_page_title) || [];
  const electionYear = election.election_date?.substring(0, 4) || '';
  const numElected = elected.length;
  const newMembers = new Set<string>();

  // Before processing this election: remove anyone who died or departed before this date
  const electionDate = election.election_date || '';
  const departed = new Set(manualDepartures.filter(d => d.date < electionDate).map(d => d.name));
  for (const cohort of cohorts) {
    cohort.members = cohort.members.filter(m => {
      if (departed.has(m.name)) return false;
      if (!m.diedDate) return true;
      return m.diedDate >= electionDate;
    });
  }
  byElectionMembers = byElectionMembers.filter(m => {
    if (departed.has(m.name)) return false;
    if (!m.diedDate) return true;
    return m.diedDate >= electionDate;
  });

  if (election.election_type === 'by-election') {
    // By-election: replace specific person, new member expires at next general
    // Track council size before removals to detect already-departed replacements
    const countBefore = new Set([...cohorts.flatMap(co => co.members.map(m => m.name)), ...byElectionMembers.map(m => m.name)]).size;

    const replacedName = election.replaced_person_name || election.replaced_person;
    if (replacedName) {
      for (const cohort of cohorts) {
        cohort.members = removePerson(cohort.members, replacedName);
      }
      byElectionMembers = removePerson(byElectionMembers, replacedName);
    }
    // Handle second replacement stored in notes (e.g. Nov 1886 by-election: 2 co-options)
    const alsoMatch = (election.notes || '').match(/Also replaced:\s*(.+)/);
    if (alsoMatch) {
      const alsoName = alsoMatch[1].trim();
      for (const cohort of cohorts) {
        cohort.members = removePerson(cohort.members, alsoName);
      }
      byElectionMembers = removePerson(byElectionMembers, alsoName);
    }

    const countAfter = new Set([...cohorts.flatMap(co => co.members.map(m => m.name)), ...byElectionMembers.map(m => m.name)]).size;
    const removedCount = countBefore - countAfter;
    // How many slots the by-election should fill: the number actually removed NOW,
    // plus any that were already vacant (removed earlier by manualDepartures/death).
    // Total elected should not push council above 12.
    const maxToAdd = Math.max(removedCount, numElected);

    for (const c of elected) {
      const name = c.person_name || c.candidate_name;
      const currentSize = new Set([...cohorts.flatMap(co => co.members.map(m => m.name)), ...byElectionMembers.map(m => m.name)]).size;
      if (currentSize >= 12) break; // Council is full, don't overshoot
      byElectionMembers.push({
        name,
        slug: c.person_slug,
        fromByElection: true,
        diedDate: deathDates.get(name) || null,
      });
      newMembers.add(name);
    }
  } else {
    // General election
    generalCount++;

    if (election.wiki_page_title === 'Lerwick Town Council Election November 1876') {
      // Special case: 1876 reform election seeded ALL THREE cohorts
      // Bottom 4 by votes → 1-year term (expire at general+1 = 1877)
      // Next 4 → 2-year term (expire at general+2 = 1878)
      // Top 4 → 3-year term (expire at general+3 = 1879)
      cohorts = [];
      byElectionMembers = [];
      // Elected are already sorted by position (vote ranking)
      const members = elected.map((c: any) => ({
        name: c.person_name || c.candidate_name,
        slug: c.person_slug,
        fromByElection: false,
        diedDate: deathDates.get(c.person_name || c.candidate_name) || null,
      }));
      // Top 4 (positions 1-4): 3-year term
      cohorts.push({
        wikiTitle: election.wiki_page_title,
        members: members.slice(0, 4),
        expiresAfterGenerals: generalCount + 3,
      });
      // Next 4 (positions 5-8): 2-year term
      cohorts.push({
        wikiTitle: election.wiki_page_title,
        members: members.slice(4, 8),
        expiresAfterGenerals: generalCount + 2,
      });
      // Bottom 4 (positions 9-12): 1-year term
      cohorts.push({
        wikiTitle: election.wiki_page_title,
        members: members.slice(8, 12),
        expiresAfterGenerals: generalCount + 1,
      });
    } else if (election.wiki_page_title === 'Lerwick Town Council Election November 1919') {
      // Special case: post-WWI reset. Elections suspended 1915-1918.
      // 7 vacancies: 2 by rotation + 5 ad interim (wartime co-options re-standing).
      // 5 non-retiring holdovers from 1914 cohort stay on.
      // Newspaper 9 Oct 1919, 18 Oct 1919, 30 Oct 1919.
      cohorts = [];
      byElectionMembers = [];
      const mkMember = (name: string): Member => ({
        name, slug: null, fromByElection: false,
        diedDate: deathDates.get(name) || null,
      });
      // Look up slugs for known holdovers
      const lookupSlug = (name: string) => {
        const p = db.prepare('SELECT slug FROM people WHERE name = ?').get(name) as any;
        return p?.slug || null;
      };
      const mkm = (name: string): Member => ({
        name, slug: lookupSlug(name), fromByElection: false,
        diedDate: deathDates.get(name) || null,
      });
      const newlyElected = elected.map((c: any) => ({
        name: c.person_name || c.candidate_name,
        slug: c.person_slug,
        fromByElection: false,
        diedDate: deathDates.get(c.person_name || c.candidate_name) || null,
      }));
      // 1-year cohort (retire 1920): Ganson, Ratter, W.Sinclair + Goodlad
      // Goodlad doesn't re-stand at 1920, comes back via Jun 1921 by-election
      cohorts.push({
        wikiTitle: election.wiki_page_title,
        members: ['Robert Ganson (i)', 'Alexander Ratter', 'William Sinclair', 'Peter Goodlad'].map(mkm),
        expiresAfterGenerals: generalCount + 1,
      });
      // 3-year cohort (retire 1922): top 4 elected by votes
      cohorts.push({
        wikiTitle: election.wiki_page_title,
        members: newlyElected.slice(0, 4),
        expiresAfterGenerals: generalCount + 3,
      });
      // 2-year cohort (retire 1921): Smith + bottom 3 elected
      // Newspaper Nov 1921: Smith, Ramsay, Sinclair, Ollason went out of office
      cohorts.push({
        wikiTitle: election.wiki_page_title,
        members: [mkm('John Smith (i)'), ...newlyElected.slice(4)],
        expiresAfterGenerals: generalCount + 2,
      });
      for (const m of newlyElected) newMembers.add(m.name);
    } else if (numElected >= 10) {
      // Full council replacement (pre-1876 triennial elections)
      cohorts = [];
      byElectionMembers = [];
      const newCohort: Member[] = elected.map((c: any) => ({
        name: c.person_name || c.candidate_name,
        slug: c.person_slug,
        fromByElection: false,
        diedDate: deathDates.get(c.person_name || c.candidate_name) || null,
      }));
      cohorts.push({
        wikiTitle: election.wiki_page_title,
        members: newCohort,
        expiresAfterGenerals: generalCount + 3,
      });
      for (const m of newCohort) newMembers.add(m.name);
    } else {
      // Annual rotation:
      // 1. Expire cohorts that have served 3 general elections
      cohorts = cohorts.filter(c => c.expiresAfterGenerals > generalCount);
      // 2. All by-election fills expire (their seats are now being contested)
      byElectionMembers = [];
      // 3. Add new cohort with all elected members initially
      const allElected: Member[] = elected.map((c: any) => ({
        name: c.person_name || c.candidate_name,
        slug: c.person_slug,
        fromByElection: false,
        diedDate: deathDates.get(c.person_name || c.candidate_name) || null,
      }));
      cohorts.push({
        wikiTitle: election.wiki_page_title,
        members: allElected,
        expiresAfterGenerals: generalCount + 3,
      });
      // 4. Redistribute: move overflow members from any cohort with >4 into
      //    earlier cohorts with <4 (earliest-expiring first, to fill gaps).
      // 4. Redistribute: move overflow members from any cohort with >4 into
      //    earlier cohorts with <4 (earliest-expiring first, to fill gaps).
      //    Skip for elections where the 5th member got a full term (no short-term re-standing
      //    at the next general). Confirmed: 1883 and 1912 (next general had only 4 vacancies).
      const skipRedistribute = new Set([
        'Lerwick Town Council Election November 1883',
        'Lerwick Town Council Election November 1912',
        'Lerwick Town Council Election November 1932',  // Newspaper Oct 1932: 5 retiring, 1933 had 4
      ]);
      if (!skipRedistribute.has(election.wiki_page_title)) {
        let moved = true;
        while (moved) {
          moved = false;
          const overflowCohort = cohorts.find(c => c.members.length > 4);
          if (overflowCohort) {
            const gapCohort = cohorts.find(c => c.members.length < 4);
            if (gapCohort) {
              gapCohort.members.push(overflowCohort.members.pop()!);
              moved = true;
            }
          }
        }
      }
      // 5. Manual cohort corrections where redistribution picked the wrong short-term fill.
      //    The pop() heuristic (lowest votes) doesn't always match the council's actual assignment.
      //    These corrections are confirmed from newspaper vacancy notices.
      const corrections: Record<string, [string, string]> = {
        // 1886: Jamieson was short-term fill, not Stove (confirmed: 1888 newspaper lists
        //        Mitchell, Tulloch, Jamieson as retiring — Stove still serving until death Apr 1889)
        'Lerwick Town Council Election November 1886': ['Laurence Stove', 'Andrew Jamieson'],
        // 1887: Anderson was short-term fill, not Charles Robertson (confirmed: 1888 newspaper
        //        says "one of the five gentlemen elected last year" must re-stand; Anderson re-elected 1888)
        'Lerwick Town Council Election November 1887': ['Charles Robertson', 'John Anderson'],
      };
      const correction = corrections[election.wiki_page_title];
      if (correction) {
        const [wrongPerson, rightPerson] = correction;
        // Find which cohorts they're in and swap them
        let wrongCohort: typeof cohorts[0] | null = null;
        let rightCohort: typeof cohorts[0] | null = null;
        for (const c of cohorts) {
          if (c.members.some(m => m.name === wrongPerson)) wrongCohort = c;
          if (c.members.some(m => m.name === rightPerson)) rightCohort = c;
        }
        if (wrongCohort && rightCohort && wrongCohort !== rightCohort) {
          const wrongMember = wrongCohort.members.find(m => m.name === wrongPerson)!;
          const rightMember = rightCohort.members.find(m => m.name === rightPerson)!;
          wrongCohort.members = wrongCohort.members.filter(m => m.name !== wrongPerson);
          rightCohort.members = rightCohort.members.filter(m => m.name !== rightPerson);
          wrongCohort.members.push(rightMember);
          rightCohort.members.push(wrongMember);
        }
      }
      for (const m of allElected) newMembers.add(m.name);
    }
  }

  // Build current council: all active cohorts + by-election fills
  const allMembers = [
    ...cohorts.flatMap(c => c.members),
    ...byElectionMembers,
  ];

  // Deduplicate by name (keep most recent if re-elected)
  const seen = new Map<string, Member>();
  for (const m of allMembers) {
    seen.set(m.name, m);
  }
  let members = Array.from(seen.values());


  // Sort: provost first (if in council), then alphabetical
  members.sort((a, b) => a.name.localeCompare(b.name));

  // Find provost
  let provost: string | null = null;
  let provostSlug: string | null = null;
  for (const p of provosts) {
    if (electionYear >= p.start_year && electionYear < p.end_year) {
      provost = p.person_name;
      if (p.person_id) {
        const person = db.prepare('SELECT slug FROM people WHERE id = ?').get(p.person_id) as any;
        if (person) provostSlug = person.slug;
      }
      break;
    }
  }

  snapshots.push({
    wikiTitle: election.wiki_page_title,
    date: election.election_date || '',
    type: election.election_type,
    electionId: election.id,
    members,
    newMembers,
    provost,
    provostSlug,
  });
}

function shortDate(d: string): string {
  if (!d) return '?';
  const date = new Date(d);
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${months[date.getMonth()]} ${date.getFullYear()}`;
}

function electionLabel(s: Snapshot): string {
  if (s.type === 'by-election') return shortDate(s.date) + ' (by)';
  return shortDate(s.date);
}

const maxSize = Math.max(...snapshots.map(s => s.members.length));
---
<Base title="Lerwick Town Council Composition">
  <div class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/council/lerwick-town-council">Lerwick Town Council</a> &rsaquo;
    Council Composition
  </div>

  <h1>Lerwick Town Council Composition</h1>
  <p class="meta">
    The full membership of the council after each election, 1818–1975.
    Scroll horizontally to navigate. Members are sorted alphabetically.
    <span class="new-legend">Highlighted</span> = newly elected at that election.
  </p>

  <div class="timeline-wrapper">
    <table class="timeline-table">
      <thead>
        <tr>
          <th class="row-label sticky-corner"></th>
          {snapshots.map(s => (
            <th class={`election-header ${s.type === 'by-election' ? 'by-election-header' : ''}`}>
              <a href={`/election/${s.electionId}`}>{electionLabel(s)}</a>
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        <tr class="provost-row">
          <td class="row-label"><strong>Provost</strong></td>
          {snapshots.map(s => (
            <td class="provost-cell">
              {s.provost
                ? (s.provostSlug
                    ? <a href={`/person/${s.provostSlug}`}>{s.provost}</a>
                    : s.provost)
                : ''}
            </td>
          ))}
        </tr>
        <tr class="count-row">
          <td class="row-label">Size</td>
          {snapshots.map(s => (
            <td class="count-cell">{s.members.length}</td>
          ))}
        </tr>
        {Array.from({ length: maxSize }, (_, row) => (
          <tr>
            <td class="row-label">{row + 1}</td>
            {snapshots.map(s => {
              const member = s.members[row];
              if (!member) return <td class="empty-cell"></td>;
              const isNew = s.newMembers.has(member.name);
              return (
                <td class={`member-cell ${isNew ? 'new-member' : ''} ${member.fromByElection ? 'by-elected' : ''}`}>
                  {member.slug
                    ? <a href={`/person/${member.slug}`}>{member.name}</a>
                    : member.name}
                </td>
              );
            })}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</Base>

<style>
  .new-legend {
    background: var(--success-light);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    font-weight: 600;
    font-size: 0.85rem;
  }

  .timeline-wrapper {
    overflow-x: auto;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    margin: 1.5rem 0;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    max-height: 80vh;
  }

  .timeline-table {
    border-collapse: collapse;
    font-size: 0.76rem;
    white-space: nowrap;
    margin: 0;
    box-shadow: none;
  }

  .timeline-table th,
  .timeline-table td {
    padding: 0.25rem 0.45rem;
    border: 1px solid var(--border-light);
    vertical-align: middle;
  }

  .row-label {
    position: sticky;
    left: 0;
    background: var(--bg-surface);
    z-index: 2;
    font-weight: 600;
    min-width: 3.5rem;
    border-right: 2px solid var(--border) !important;
    text-align: center;
  }

  .sticky-corner {
    z-index: 4;
    position: sticky;
    top: 0;
    left: 0;
  }

  thead th {
    position: sticky;
    top: 0;
    z-index: 3;
  }

  .election-header {
    background: var(--table-header-bg);
    color: var(--table-header-text);
    text-align: center;
    font-size: 0.7rem;
    min-width: 5.5rem;
    font-weight: 500;
  }

  .election-header a { color: var(--table-header-text); }

  .by-election-header {
    background: var(--warning-bg);
    color: var(--warning-text);
  }

  .by-election-header a { color: var(--warning-text); }

  .provost-row td {
    background: var(--accent-light);
    font-weight: 600;
    font-size: 0.73rem;
  }

  .provost-row .row-label {
    background: var(--accent-light);
  }

  .count-row td {
    text-align: center;
    font-weight: 600;
    font-size: 0.7rem;
    color: var(--muted);
  }

  .member-cell {
    font-size: 0.73rem;
  }

  .new-member {
    background: var(--success-light);
    font-weight: 600;
  }

  .by-elected {
    font-style: italic;
  }

  .empty-cell {
    background: var(--bg-surface-alt);
  }
</style>
