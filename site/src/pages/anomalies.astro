---
import Base from '../layouts/Base.astro';
import Database from 'better-sqlite3';
import path from 'path';

const db = new Database(path.join(process.cwd(), 'shetland.db'), { readonly: true });

// 1. People with dates but no candidacies
const noCandidacies = db.prepare(`
  SELECT p.name, p.slug, p.born_date, p.died_date
  FROM people p
  LEFT JOIN candidacies c ON c.person_id = p.id
  WHERE c.id IS NULL
  ORDER BY p.name
`).all() as any[];

// 2. Unlinked candidacies (no person_id) - group by candidate name to find potential matches
const unlinkedCandidacies = db.prepare(`
  SELECT c.candidate_name, COUNT(*) as appearances,
         GROUP_CONCAT(DISTINCT SUBSTR(e.election_date, 1, 4)) as years,
         GROUP_CONCAT(DISTINCT co.name) as councils
  FROM candidacies c
  JOIN elections e ON c.election_id = e.id
  JOIN councils co ON e.council_id = co.id
  WHERE c.person_id IS NULL
  GROUP BY c.candidate_name
  ORDER BY COUNT(*) DESC
`).all() as any[];

// 3. Unlinked candidacies where a similarly-named person exists (potential fixable links)
const potentialMatches = db.prepare(`
  SELECT c.candidate_name, p.name as person_name, p.slug, p.born_date, p.died_date,
         COUNT(*) as appearances,
         GROUP_CONCAT(DISTINCT SUBSTR(e.election_date, 1, 4)) as years
  FROM candidacies c
  JOIN elections e ON c.election_id = e.id
  JOIN people p ON LOWER(REPLACE(c.candidate_name, '.', '')) LIKE '%' || LOWER(REPLACE(REPLACE(p.name, ' (i)', ''), ' (ii)', '')) || '%'
  WHERE c.person_id IS NULL
    AND LENGTH(p.name) > 5
  GROUP BY c.candidate_name, p.name
  ORDER BY c.candidate_name
`).all() as any[];

// 4. People with very long lifespans (possible date errors)
const longLived = db.prepare(`
  SELECT name, slug, born_date, died_date,
         CAST(SUBSTR(died_date, 1, 4) AS INTEGER) - CAST(SUBSTR(born_date, 1, 4) AS INTEGER) as age
  FROM people
  WHERE born_date IS NOT NULL AND died_date IS NOT NULL
    AND CAST(SUBSTR(died_date, 1, 4) AS INTEGER) - CAST(SUBSTR(born_date, 1, 4) AS INTEGER) > 95
  ORDER BY age DESC
`).all() as any[];

// 5. People who died before they were born
const diedBeforeBorn = db.prepare(`
  SELECT name, slug, born_date, died_date
  FROM people
  WHERE born_date IS NOT NULL AND died_date IS NOT NULL
    AND CAST(SUBSTR(died_date, 1, 4) AS INTEGER) < CAST(SUBSTR(born_date, 1, 4) AS INTEGER)
  ORDER BY name
`).all() as any[];

// 7. Elections with no date
const noDateElections = db.prepare(`
  SELECT e.id, e.wiki_page_title, e.election_type, co.name as council_name
  FROM elections e
  JOIN councils co ON e.council_id = co.id
  WHERE e.election_date IS NULL
  ORDER BY e.wiki_page_title
`).all() as any[];

// 8. Candidacies where elected person got fewer votes than non-elected
const voteAnomalies = db.prepare(`
  SELECT e.wiki_page_title, e.election_date, con.name as constituency_name,
         w.candidate_name as winner_name, w.votes as winner_votes,
         l.candidate_name as loser_name, l.votes as loser_votes
  FROM candidacies w
  JOIN elections e ON w.election_id = e.id
  LEFT JOIN constituencies con ON e.constituency_id = con.id
  JOIN candidacies l ON l.election_id = w.election_id AND l.id != w.id
  WHERE w.elected = 1 AND l.elected = 0
    AND w.votes IS NOT NULL AND l.votes IS NOT NULL
    AND w.votes < l.votes
    AND w.votes > 0
  ORDER BY e.election_date
`).all() as any[];

// 9. Duplicate person slugs / very similar names
const similarNames = db.prepare(`
  SELECT a.name as name1, a.slug as slug1, a.born_date as born1, a.died_date as died1,
         b.name as name2, b.slug as slug2, b.born_date as born2, b.died_date as died2
  FROM people a
  JOIN people b ON a.id < b.id
  WHERE REPLACE(REPLACE(REPLACE(a.name, ' (i)', ''), ' (ii)', ''), ' (iii)', '')
      = REPLACE(REPLACE(REPLACE(b.name, ' (i)', ''), ' (ii)', ''), ' (iii)', '')
  ORDER BY a.name
`).all() as any[];

// 10. People with elected service spanning an unusually long period
const longCareers = db.prepare(`
  SELECT p.name, p.slug, p.born_date, p.died_date,
         MIN(e.election_date) as first_election, MAX(e.election_date) as last_election,
         CAST(SUBSTR(MAX(e.election_date), 1, 4) AS INTEGER) - CAST(SUBSTR(MIN(e.election_date), 1, 4) AS INTEGER) as span,
         COUNT(*) as num_candidacies
  FROM people p
  JOIN candidacies c ON c.person_id = p.id
  JOIN elections e ON c.election_id = e.id
  WHERE e.election_date IS NOT NULL AND c.elected = 1
  GROUP BY p.id
  HAVING span > 40
  ORDER BY span DESC
`).all() as any[];

// 11. People with no biography and no intro
const noBio = db.prepare(`
  SELECT p.name, p.slug, p.born_date, p.died_date,
         COUNT(c.id) as candidacies
  FROM people p
  LEFT JOIN candidacies c ON c.person_id = p.id
  WHERE (p.intro IS NULL OR p.intro = '') AND (p.biography IS NULL OR p.biography = '')
  GROUP BY p.id
  ORDER BY COUNT(c.id) DESC
`).all() as any[];

// 12. Elections where all candidates are unopposed (but >1 candidate)
const multiUnopposed = db.prepare(`
  SELECT e.wiki_page_title, e.election_date, con.name as constituency_name,
         COUNT(*) as num_candidates,
         SUM(c.elected) as num_elected
  FROM elections e
  JOIN candidacies c ON c.election_id = e.id
  LEFT JOIN constituencies con ON e.constituency_id = con.id
  WHERE c.votes IS NULL AND c.votes_text IS NOT NULL
  GROUP BY e.id
  HAVING num_candidates > 1 AND num_elected = num_candidates
  ORDER BY e.election_date
`).all() as any[];

// Summary stats
const totalPeople = (db.prepare('SELECT COUNT(*) as c FROM people').get() as any).c;
const totalCandidacies = (db.prepare('SELECT COUNT(*) as c FROM candidacies').get() as any).c;
const linkedCandidacies = (db.prepare('SELECT COUNT(*) as c FROM candidacies WHERE person_id IS NOT NULL').get() as any).c;
const totalElections = (db.prepare('SELECT COUNT(*) as c FROM elections').get() as any).c;
---
<Base title="Data Anomalies">
  <div class="breadcrumb"><a href="/">Home</a> &rsaquo; Data Anomalies</div>
  <h1>Data Anomalies</h1>
  <p class="meta">Analysis of potential data quality issues. {totalPeople} people, {totalCandidacies} candidacies ({linkedCandidacies} linked, {totalCandidacies - linkedCandidacies} unlinked), {totalElections} elections.</p>

  <nav style="margin-bottom: 2rem; padding: 1rem; background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow-sm);">
    <strong>Jump to:</strong>
    <ul style="list-style: none; columns: 2; margin-top: 0.5rem;">
      {diedBeforeBorn.length > 0 && <li><a href="#died-before-born">Death before birth ({diedBeforeBorn.length})</a></li>}
      {longLived.length > 0 && <li><a href="#long-lived">Unusually long lifespans ({longLived.length})</a></li>}
      {longCareers.length > 0 && <li><a href="#long-careers">Very long careers ({longCareers.length})</a></li>}
      {voteAnomalies.length > 0 && <li><a href="#vote-anomalies">Vote count anomalies ({voteAnomalies.length})</a></li>}
      <li><a href="#similar-names">Disambiguated names ({similarNames.length} pairs)</a></li>
      <li><a href="#unlinked">Unlinked candidacies ({unlinkedCandidacies.length} names)</a></li>
      <li><a href="#potential-matches">Potential matches for unlinked ({potentialMatches.length})</a></li>
      <li><a href="#no-candidacies">People with no candidacies ({noCandidacies.length})</a></li>
      <li><a href="#no-bio">People with no biography ({noBio.length})</a></li>
      <li><a href="#no-date">Elections with no date ({noDateElections.length})</a></li>
    </ul>
  </nav>

  {diedBeforeBorn.length > 0 && (
    <section>
      <h2 id="died-before-born">Death date before birth date</h2>
      <p class="meta">These people have a death date earlier than their birth date — one of the dates is wrong.</p>
      <table>
        <thead><tr><th>Person</th><th>Born</th><th>Died</th></tr></thead>
        <tbody>
          {diedBeforeBorn.map((p: any) => (
            <tr>
              <td><a href={`/person/${p.slug}`}>{p.name}</a></td>
              <td>{p.born_date}</td>
              <td>{p.died_date}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}

  {longLived.length > 0 && (
    <section>
      <h2 id="long-lived">Unusually long lifespans (95+ years)</h2>
      <p class="meta">These ages may indicate a date error, or they were simply very long-lived.</p>
      <table>
        <thead><tr><th>Person</th><th>Born</th><th>Died</th><th>Age</th></tr></thead>
        <tbody>
          {longLived.map((p: any) => (
            <tr>
              <td><a href={`/person/${p.slug}`}>{p.name}</a></td>
              <td>{p.born_date}</td>
              <td>{p.died_date}</td>
              <td>{p.age}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}

  {longCareers.length > 0 && (
    <section>
      <h2 id="long-careers">Very long political careers (40+ years)</h2>
      <p class="meta">Careers spanning 40+ years may indicate incorrect person linkage (different people with the same name).</p>
      <table>
        <thead><tr><th>Person</th><th>Born</th><th>Died</th><th>First election</th><th>Last election</th><th>Span</th><th>Candidacies</th></tr></thead>
        <tbody>
          {longCareers.map((p: any) => (
            <tr>
              <td><a href={`/person/${p.slug}`}>{p.name}</a></td>
              <td>{p.born_date || '?'}</td>
              <td>{p.died_date || '?'}</td>
              <td>{p.first_election}</td>
              <td>{p.last_election}</td>
              <td>{p.span} years</td>
              <td>{p.num_candidacies}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}

  {voteAnomalies.length > 0 && (
    <section>
      <h2 id="vote-anomalies">Vote count anomalies</h2>
      <p class="meta">Elections where an elected candidate received fewer votes than a non-elected candidate. May indicate multi-seat elections, STV counting, or data errors.</p>
      <table>
        <thead><tr><th>Election</th><th>Date</th><th>Constituency</th><th>Winner (votes)</th><th>Non-winner (votes)</th></tr></thead>
        <tbody>
          {voteAnomalies.map((v: any) => (
            <tr>
              <td>{v.wiki_page_title.replaceAll('_', ' ')}</td>
              <td>{v.election_date}</td>
              <td>{v.constituency_name || ''}</td>
              <td>{v.winner_name} ({v.winner_votes})</td>
              <td>{v.loser_name} ({v.loser_votes})</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}

  <section>
    <h2 id="similar-names">Disambiguated name pairs</h2>
    <p class="meta">People sharing the same base name. These are the most likely source of mislinked candidacies.</p>
    <table>
      <thead><tr><th>Person 1</th><th>Dates</th><th>Person 2</th><th>Dates</th></tr></thead>
      <tbody>
        {similarNames.map((s: any) => (
          <tr>
            <td><a href={`/person/${s.slug1}`}>{s.name1}</a></td>
            <td>{s.born1 ? s.born1.substring(0, 4) : '?'}{s.died1 ? `\u2013${s.died1.substring(0, 4)}` : ''}</td>
            <td><a href={`/person/${s.slug2}`}>{s.name2}</a></td>
            <td>{s.born2 ? s.born2.substring(0, 4) : '?'}{s.died2 ? `\u2013${s.died2.substring(0, 4)}` : ''}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section>
    <h2 id="unlinked">Unlinked candidacies</h2>
    <p class="meta">{unlinkedCandidacies.reduce((sum: number, u: any) => sum + u.appearances, 0)} candidacies across {unlinkedCandidacies.length} distinct names with no linked person record.</p>
    <table>
      <thead><tr><th>Candidate name</th><th>Appearances</th><th>Years</th><th>Councils</th></tr></thead>
      <tbody>
        {unlinkedCandidacies.map((u: any) => (
          <tr>
            <td>{u.candidate_name}</td>
            <td>{u.appearances}</td>
            <td style="font-size: 0.8rem;">{u.years}</td>
            <td style="font-size: 0.8rem;">{u.councils}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  {potentialMatches.length > 0 && (
    <section>
      <h2 id="potential-matches">Potential matches for unlinked candidacies</h2>
      <p class="meta">Unlinked candidates whose name is similar to an existing person record. These may be linkable.</p>
      <table>
        <thead><tr><th>Candidate name</th><th>Years</th><th>Appearances</th><th>Possible match</th><th>Dates</th></tr></thead>
        <tbody>
          {potentialMatches.map((m: any) => (
            <tr>
              <td>{m.candidate_name}</td>
              <td>{m.years}</td>
              <td>{m.appearances}</td>
              <td><a href={`/person/${m.slug}`}>{m.person_name}</a></td>
              <td>{m.born_date ? m.born_date.substring(0, 4) : '?'}{m.died_date ? `\u2013${m.died_date.substring(0, 4)}` : ''}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}

  <section>
    <h2 id="no-candidacies">People with no candidacies</h2>
    <p class="meta">{noCandidacies.length} people in the database not linked to any election.</p>
    <table>
      <thead><tr><th>Person</th><th>Born</th><th>Died</th></tr></thead>
      <tbody>
        {noCandidacies.map((p: any) => (
          <tr>
            <td><a href={`/person/${p.slug}`}>{p.name}</a></td>
            <td>{p.born_date || ''}</td>
            <td>{p.died_date || ''}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  {noBio.length > 0 && (
    <section>
      <h2 id="no-bio">People with no biography text</h2>
      <p class="meta">{noBio.length} people with no intro or biography content.</p>
      <table>
        <thead><tr><th>Person</th><th>Born</th><th>Died</th><th>Candidacies</th></tr></thead>
        <tbody>
          {noBio.map((p: any) => (
            <tr>
              <td><a href={`/person/${p.slug}`}>{p.name}</a></td>
              <td>{p.born_date || ''}</td>
              <td>{p.died_date || ''}</td>
              <td>{p.candidacies}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}


  {noDateElections.length > 0 && (
    <section>
      <h2 id="no-date">Elections with no date</h2>
      <table>
        <thead><tr><th>Election</th><th>Type</th><th>Council</th></tr></thead>
        <tbody>
          {noDateElections.map((e: any) => (
            <tr>
              <td>{e.wiki_page_title.replaceAll('_', ' ')}</td>
              <td>{e.election_type}</td>
              <td>{e.council_name}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}
</Base>
