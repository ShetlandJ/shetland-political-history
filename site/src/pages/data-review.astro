---
import Base from '../layouts/Base.astro';
import Database from 'better-sqlite3';
import path from 'path';

const db = new Database(path.join(process.cwd(), 'shetland.db'), { readonly: true });

// By-election replacement status
const byElectionStatus = db.prepare(`
  SELECT e.id, e.wiki_page_title, e.election_date, e.election_type,
         e.replaced_person, e.replaced_person_id,
         rp.name as replaced_person_name, rp.slug as replaced_person_slug,
         co.name as council_name, co.slug as council_slug
  FROM elections e
  JOIN councils co ON e.council_id = co.id
  LEFT JOIN people rp ON e.replaced_person_id = rp.id
  WHERE e.election_type = 'by-election' AND e.hidden = 0
  ORDER BY e.election_date
`).all() as any[];

const missing = byElectionStatus.filter((e: any) => !e.replaced_person || e.replaced_person === '[unfilled seat]');
const notAReplacement = new Set(['[unfilled seat]', '[voided election re-run]']);
const genuinelyUnknown = missing.filter((e: any) => !notAReplacement.has(e.replaced_person));
const unfilledSeats = missing.filter((e: any) => notAReplacement.has(e.replaced_person));
const unlinked = byElectionStatus.filter((e: any) => e.replaced_person && !e.replaced_person_id);
const linked = byElectionStatus.filter((e: any) => e.replaced_person_id);

// Council composition anomalies — compute inline
const ltcId = (db.prepare("SELECT id FROM councils WHERE slug = 'lerwick-town-council'").get() as any).id;

const ltcElections = db.prepare(`
  SELECT MIN(e.id) as id, e.wiki_page_title, e.election_date, e.election_type, e.replaced_person,
         rp.name as replaced_person_name, e.notes
  FROM elections e
  LEFT JOIN people rp ON e.replaced_person_id = rp.id
  WHERE e.council_id = ? AND e.hidden = 0
  GROUP BY e.wiki_page_title ORDER BY e.election_date
`).all(ltcId) as any[];

const deaths = new Map<string, string>();
for (const r of db.prepare("SELECT name, died_date FROM people WHERE died_date IS NOT NULL").all() as any[]) {
  deaths.set(r.name, r.died_date);
}

// Mid-term departures not recorded as by-elections in the wiki data.
const manualDepartures: { name: string; date: string }[] = [
  { name: 'Thomas Cameron', date: '1883-09-01' },
  { name: 'William Duncan (i)', date: '1886-07-12' },
  { name: 'John Harrison (i)', date: '1886-10-01' },
  { name: 'Alexander Mitchell (i)', date: '1889-09-01' },
  { name: 'William MacDougall', date: '1912-04-01' },
  { name: 'William Sinclair', date: '1921-10-01' },
];

function getElected(wt: string) {
  return db.prepare(`
    SELECT c.candidate_name, p.name as person_name
    FROM candidacies c JOIN elections e ON c.election_id = e.id
    LEFT JOIN people p ON c.person_id = p.id
    WHERE e.wiki_page_title = ? AND c.elected = 1 AND e.hidden = 0 ORDER BY c.position
  `).all(wt) as any[];
}

function removePerson(lst: string[], name: string): string[] {
  const clean = name.replace(/\s*\([^)]*\)\s*$/, '');
  return lst.filter(m => m !== name && m.replace(/\s*\([^)]*\)\s*$/, '') !== clean);
}

let cohorts: { members: string[]; exp: number }[] = [];
let byMembers: string[] = [];
let generalCount = 0;

interface Anomaly {
  date: string;
  type: string;
  size: number;
  wikiTitle: string;
  direction: string;
  electionId: number;
}

const anomalies: Anomaly[] = [];

for (const e of ltcElections) {
  const elected = getElected(e.wiki_page_title);
  const num = elected.length;
  const edate: string = e.election_date || '';
  const year = edate.substring(0, 4);

  const departed = new Set(manualDepartures.filter(d => d.date < edate).map(d => d.name));
  for (const c of cohorts) {
    c.members = c.members.filter(m => !departed.has(m) && (deaths.get(m) || '9999') >= edate);
  }
  byMembers = byMembers.filter(m => !departed.has(m) && (deaths.get(m) || '9999') >= edate);

  if (e.election_type === 'by-election') {
    const replaced = e.replaced_person_name || e.replaced_person;
    if (replaced) {
      for (const c of cohorts) c.members = removePerson(c.members, replaced);
      byMembers = removePerson(byMembers, replaced);
    }
    const notes: string = e.notes || '';
    const also = notes.match(/Also replaced:\s*(.+)/);
    if (also) {
      for (const c of cohorts) c.members = removePerson(c.members, also[1].trim());
      byMembers = removePerson(byMembers, also[1].trim());
    }
    for (const c of elected) byMembers.push(c.person_name || c.candidate_name);
  } else {
    generalCount++;
    if (e.wiki_page_title === 'Lerwick Town Council Election November 1876') {
      cohorts = []; byMembers = [];
      const members = elected.map((c: any) => c.person_name || c.candidate_name);
      cohorts.push({ members: members.slice(0, 4), exp: generalCount + 3 });
      cohorts.push({ members: members.slice(4, 8), exp: generalCount + 2 });
      cohorts.push({ members: members.slice(8, 12), exp: generalCount + 1 });
    } else if (e.wiki_page_title === 'Lerwick Town Council Election November 1919') {
      // Post-WWI reset: hardcoded cohort assignments from newspaper evidence
      cohorts = []; byMembers = [];
      const electedNames = elected.map((c: any) => c.person_name || c.candidate_name);
      cohorts.push({ members: ['Robert Ganson (i)', 'Alexander Ratter', 'William Sinclair', 'Peter Goodlad'], exp: generalCount + 1 });
      cohorts.push({ members: electedNames.slice(0, 4), exp: generalCount + 3 });
      cohorts.push({ members: ['John Smith (i)', ...electedNames.slice(4)], exp: generalCount + 2 });
    } else if (num >= 10) {
      cohorts = []; byMembers = [];
      cohorts.push({ members: elected.map((c: any) => c.person_name || c.candidate_name), exp: generalCount + 3 });
    } else {
      cohorts = cohorts.filter(c => c.exp > generalCount);
      byMembers = [];
      cohorts.push({ members: elected.map((c: any) => c.person_name || c.candidate_name), exp: generalCount + 3 });
      let moved = true;
      while (moved) {
        moved = false;
        const overflowCohort = cohorts.find(c => c.members.length > 4);
        if (overflowCohort) {
          const gapCohort = cohorts.find(c => c.members.length < 4);
          if (gapCohort) {
            gapCohort.members.push(overflowCohort.members.pop()!);
            moved = true;
          }
        }
      }
      // Manual cohort corrections where redistribution picked the wrong short-term fill
      const corrections: Record<string, [string, string]> = {
        'Lerwick Town Council Election November 1886': ['Laurence Stove', 'Andrew Jamieson'],
        'Lerwick Town Council Election November 1887': ['Charles Robertson', 'John Anderson'],
      };
      const corr = corrections[e.wiki_page_title];
      if (corr) {
        const [wrong, right] = corr;
        let wc = cohorts.find(c => c.members.includes(wrong));
        let rc = cohorts.find(c => c.members.includes(right));
        if (wc && rc && wc !== rc) {
          wc.members = wc.members.filter((m: string) => m !== wrong);
          rc.members = rc.members.filter((m: string) => m !== right);
          wc.members.push(right);
          rc.members.push(wrong);
        }
      }
    }
  }

  const allNames = new Set<string>();
  for (const c of cohorts) for (const m of c.members) allNames.add(m);
  for (const m of byMembers) allNames.add(m);
  const size = allNames.size;

  if (year && parseInt(year) > 1877 && size !== 12) {
    anomalies.push({
      date: edate,
      type: e.election_type,
      size,
      wikiTitle: e.wiki_page_title,
      direction: size > 12 ? 'over' : 'under',
      electionId: e.id,
    });
  }
}

// People with no candidacies
const noCandidacies = db.prepare(`
  SELECT p.name, p.slug, p.born_date, p.died_date
  FROM people p LEFT JOIN candidacies c ON c.person_id = p.id
  WHERE c.id IS NULL ORDER BY p.name
`).all() as any[];

// Unlinked candidacies
const unlinkedCandidacies = db.prepare(`
  SELECT c.candidate_name, COUNT(*) as n,
         GROUP_CONCAT(DISTINCT SUBSTR(e.election_date, 1, 4)) as years
  FROM candidacies c JOIN elections e ON c.election_id = e.id
  WHERE c.person_id IS NULL AND e.hidden = 0
  GROUP BY c.candidate_name ORDER BY COUNT(*) DESC
`).all() as any[];

const totalUnlinked = unlinkedCandidacies.reduce((sum: number, u: any) => sum + u.n, 0);

// --- Anomaly checks (merged from anomalies.astro) ---

const diedBeforeBorn = db.prepare(`
  SELECT name, slug, born_date, died_date FROM people
  WHERE born_date IS NOT NULL AND died_date IS NOT NULL
    AND CAST(SUBSTR(died_date, 1, 4) AS INTEGER) < CAST(SUBSTR(born_date, 1, 4) AS INTEGER)
  ORDER BY name
`).all() as any[];

const longLived = db.prepare(`
  SELECT name, slug, born_date, died_date,
         CAST(SUBSTR(died_date, 1, 4) AS INTEGER) - CAST(SUBSTR(born_date, 1, 4) AS INTEGER) as age
  FROM people WHERE born_date IS NOT NULL AND died_date IS NOT NULL
    AND CAST(SUBSTR(died_date, 1, 4) AS INTEGER) - CAST(SUBSTR(born_date, 1, 4) AS INTEGER) > 95
  ORDER BY age DESC
`).all() as any[];

const longCareers = db.prepare(`
  SELECT p.name, p.slug, p.born_date, p.died_date,
         MIN(e.election_date) as first_election, MAX(e.election_date) as last_election,
         CAST(SUBSTR(MAX(e.election_date), 1, 4) AS INTEGER) - CAST(SUBSTR(MIN(e.election_date), 1, 4) AS INTEGER) as span,
         COUNT(*) as num_candidacies
  FROM people p JOIN candidacies c ON c.person_id = p.id JOIN elections e ON c.election_id = e.id
  WHERE e.election_date IS NOT NULL AND c.elected = 1
  GROUP BY p.id HAVING span > 40 ORDER BY span DESC
`).all() as any[];

const voteAnomalies = db.prepare(`
  SELECT (SELECT MIN(e2.id) FROM elections e2 WHERE e2.wiki_page_title = e.wiki_page_title AND e2.hidden = 0) as election_id,
         e.wiki_page_title, e.election_date, con.name as constituency_name,
         w.candidate_name as winner_name, w.votes as winner_votes, wp.slug as winner_slug,
         l.candidate_name as loser_name, l.votes as loser_votes, lp.slug as loser_slug
  FROM candidacies w
  JOIN elections e ON w.election_id = e.id
  JOIN candidacies l ON l.election_id = w.election_id AND l.id != w.id
  LEFT JOIN constituencies con ON e.constituency_id = con.id
  LEFT JOIN people wp ON w.person_id = wp.id
  LEFT JOIN people lp ON l.person_id = lp.id
  WHERE w.elected = 1 AND l.elected = 0 AND w.votes IS NOT NULL AND l.votes IS NOT NULL
    AND w.votes < l.votes AND w.votes > 0 AND e.hidden = 0
  ORDER BY e.election_date
`).all() as any[];

const similarNames = db.prepare(`
  SELECT a.name as name1, a.slug as slug1, a.born_date as born1, a.died_date as died1,
         b.name as name2, b.slug as slug2, b.born_date as born2, b.died_date as died2
  FROM people a JOIN people b ON a.id < b.id
  WHERE REPLACE(REPLACE(REPLACE(a.name, ' (i)', ''), ' (ii)', ''), ' (iii)', '')
      = REPLACE(REPLACE(REPLACE(b.name, ' (i)', ''), ' (ii)', ''), ' (iii)', '')
  ORDER BY a.name
`).all() as any[];

const potentialMatches = db.prepare(`
  SELECT c.candidate_name, p.name as person_name, p.slug, p.born_date, p.died_date,
         COUNT(*) as appearances, GROUP_CONCAT(DISTINCT SUBSTR(e.election_date, 1, 4)) as years
  FROM candidacies c JOIN elections e ON c.election_id = e.id
  JOIN people p ON LOWER(REPLACE(c.candidate_name, '.', '')) LIKE '%' || LOWER(REPLACE(REPLACE(p.name, ' (i)', ''), ' (ii)', '')) || '%'
  WHERE c.person_id IS NULL AND LENGTH(p.name) > 5
  GROUP BY c.candidate_name, p.name ORDER BY c.candidate_name
`).all() as any[];

const noBio = db.prepare(`
  SELECT p.name, p.slug, p.born_date, p.died_date, COUNT(c.id) as candidacies
  FROM people p LEFT JOIN candidacies c ON c.person_id = p.id
  WHERE (p.intro IS NULL OR p.intro = '') AND (p.biography IS NULL OR p.biography = '')
  GROUP BY p.id ORDER BY COUNT(c.id) DESC
`).all() as any[];

const noDateElections = db.prepare(`
  SELECT e.id, e.wiki_page_title, e.election_type, co.name as council_name
  FROM elections e JOIN councils co ON e.council_id = co.id
  WHERE e.election_date IS NULL ORDER BY e.wiki_page_title
`).all() as any[];

const totalPeople = (db.prepare('SELECT COUNT(*) as c FROM people').get() as any).c;
const totalCandidacies = (db.prepare('SELECT COUNT(*) as c FROM candidacies').get() as any).c;
const linkedCandidacies = (db.prepare('SELECT COUNT(*) as c FROM candidacies WHERE person_id IS NOT NULL').get() as any).c;
const totalElections = (db.prepare('SELECT COUNT(*) as c FROM elections WHERE hidden = 0').get() as any).c;
---
<Base title="Data Review">
  <div class="breadcrumb"><a href="/">Home</a> &rsaquo; Data Review</div>
  <h1>Data Review</h1>
  <p class="meta">Data quality checks and items needing research. This page is a working tool, not a public-facing feature.</p>

  <p class="meta">{totalPeople} people, {totalCandidacies} candidacies ({linkedCandidacies} linked, {totalCandidacies - linkedCandidacies} unlinked), {totalElections} elections.</p>

  <nav class="review-nav">
    <strong>Sections:</strong>
    <ul style="list-style: none; columns: 2; margin-top: 0.5rem;">
      {diedBeforeBorn.length > 0 && <li><a href="#died-before-born">Death before birth ({diedBeforeBorn.length})</a></li>}
      {longLived.length > 0 && <li><a href="#long-lived">Long lifespans ({longLived.length})</a></li>}
      {longCareers.length > 0 && <li><a href="#long-careers">Long careers ({longCareers.length})</a></li>}
      {voteAnomalies.length > 0 && <li><a href="#vote-anomalies">Vote anomalies ({voteAnomalies.length})</a></li>}
      <li><a href="#similar-names">Disambiguated names ({similarNames.length})</a></li>
      <li><a href="#composition">LTC composition ({anomalies.length} anomalies)</a></li>
      <li><a href="#by-elections">By-election replacements ({genuinelyUnknown.length} unknown)</a></li>
      <li><a href="#unlinked-cands">Unlinked candidacies ({totalUnlinked})</a></li>
      {potentialMatches.length > 0 && <li><a href="#potential-matches">Potential matches ({potentialMatches.length})</a></li>}
      <li><a href="#no-candidacies">People with no elections ({noCandidacies.length})</a></li>
      {noBio.length > 0 && <li><a href="#no-bio">No biography ({noBio.length})</a></li>}
      {noDateElections.length > 0 && <li><a href="#no-date">No date ({noDateElections.length})</a></li>}
    </ul>
  </nav>

  <details>
    <summary><h2 id="composition">LTC Composition Anomalies</h2></summary>
    <p class="meta">Expected council size: 12 (post-1877). Showing elections where the computed size differs. "Over" means unresolved departures; "under" means unfilled seats.</p>
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Type</th>
          <th>Size</th>
          <th>Issue</th>
          <th>Election</th>
        </tr>
      </thead>
      <tbody>
        {anomalies.map(a => (
          <tr>
            <td>{a.date}</td>
            <td><span class={`badge badge-${a.type}`}>{a.type}</span></td>
            <td class={a.direction === 'over' ? 'danger' : 'warning'}><strong>{a.size}</strong></td>
            <td>{a.direction === 'over' ? `+${a.size - 12} extra` : `${12 - a.size} missing`}</td>
            <td><a href={`/election/${a.electionId}`}>{a.wikiTitle.replace(/_/g, ' ')}</a></td>
          </tr>
        ))}
      </tbody>
    </table>
  </details>

  <details>
    <summary><h2 id="by-elections">By-Election Replacements</h2></summary>
    <p class="meta">{linked.length} linked, {unlinked.length} parsed but unlinked, {genuinelyUnknown.length} unknown, {unfilledSeats.length} unfilled seats (no nomination at previous election).</p>

    {genuinelyUnknown.length > 0 && (
      <>
        <h3>Unknown — who did they replace?</h3>
        <table>
          <thead><tr><th>By-Election</th><th>Date</th><th>Council</th><th>Links</th></tr></thead>
          <tbody>
            {genuinelyUnknown.map((e: any) => (
              <tr>
                <td>{e.wiki_page_title.replace(/_/g, ' ')}</td>
                <td>{e.election_date}</td>
                <td>{e.council_name}</td>
                <td>
                  <a href={`/election/${e.id}`}>page</a> &middot;
                  <a href={`https://shetlandhistory.com/${e.wiki_page_title.replace(/ /g, '_')}`} target="_blank" rel="noopener">wiki</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </>
    )}

    {unlinked.length > 0 && (
      <>
        <h3>Parsed but not linked to person record</h3>
        <table>
          <thead><tr><th>By-Election</th><th>Replaced (text)</th><th>Council</th><th>Links</th></tr></thead>
          <tbody>
            {unlinked.map((e: any) => (
              <tr>
                <td>{e.wiki_page_title.replace(/_/g, ' ')}</td>
                <td>{e.replaced_person}</td>
                <td>{e.council_name}</td>
                <td>
                  <a href={`/election/${e.id}`}>page</a> &middot;
                  <a href={`https://shetlandhistory.com/${e.wiki_page_title.replace(/ /g, '_')}`} target="_blank" rel="noopener">wiki</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </>
    )}
  </details>

  <details>
    <summary><h2 id="unlinked-cands">Unlinked Candidacies</h2></summary>
    <p class="meta">{totalUnlinked} candidacies across {unlinkedCandidacies.length} names with no linked person record.</p>

    {(() => {
      const partyNames = new Set(['Labour','Conservative','Scottish National Party','Unionist','Liberal Unionist','UKIP','Scottish Socialist','Natural Law','Liberal','Liberal Democrat','Green','SNP','Alliance','Coalition Liberal','Ind. Liberal','National Liberal','Ind Conservative']);
      const parties = unlinkedCandidacies.filter((u: any) => partyNames.has(u.candidate_name));
      const external = unlinkedCandidacies.filter((u: any) => u.candidate_name.startsWith('[http'));
      const people = unlinkedCandidacies.filter((u: any) => !partyNames.has(u.candidate_name) && !u.candidate_name.startsWith('[http'));
      return { parties, external, people };
    })() && null}

    <h3>Party names parsed as candidates ({unlinkedCandidacies.filter((u: any) => ['Labour','Conservative','Scottish National Party','Unionist','Liberal Unionist','UKIP','Scottish Socialist','Natural Law'].includes(u.candidate_name)).length} — Westminster parsing bug)</h3>
    <table>
      <thead><tr><th>Name</th><th>Appearances</th><th>Years</th></tr></thead>
      <tbody>
        {unlinkedCandidacies.filter((u: any) => ['Labour','Conservative','Scottish National Party','Unionist','Liberal Unionist','UKIP','Scottish Socialist','Natural Law','Liberal','Liberal Democrat','Green','SNP','Alliance'].includes(u.candidate_name)).map((u: any) => (
          <tr>
            <td><em>{u.candidate_name}</em></td>
            <td>{u.n}</td>
            <td style="font-size: 0.8rem;">{u.years}</td>
          </tr>
        ))}
      </tbody>
    </table>

    <h3>External link candidates ({unlinkedCandidacies.filter((u: any) => u.candidate_name.startsWith('[http')).length} — have Bayanne links, no person page)</h3>
    <table>
      <thead><tr><th>Name</th><th>Appearances</th><th>Years</th></tr></thead>
      <tbody>
        {unlinkedCandidacies.filter((u: any) => u.candidate_name.startsWith('[http')).map((u: any) => {
          const m = u.candidate_name.match(/\[https?:\/\/[^\s\]]+\s+([^\]]+)\]/);
          const display = m ? m[1] : u.candidate_name;
          const urlm = u.candidate_name.match(/\[(https?:\/\/[^\s\]]+)/);
          const url = urlm ? urlm[1] : null;
          return (
            <tr>
              <td>{url ? <a href={url} target="_blank" rel="noopener">{display}</a> : display}</td>
              <td>{u.n}</td>
              <td style="font-size: 0.8rem;">{u.years}</td>
            </tr>
          );
        })}
      </tbody>
    </table>

    <h3>People without person pages ({unlinkedCandidacies.filter((u: any) => !['Labour','Conservative','Scottish National Party','Unionist','Liberal Unionist','UKIP','Scottish Socialist','Natural Law','Liberal','Liberal Democrat','Green','SNP','Alliance'].includes(u.candidate_name) && !u.candidate_name.startsWith('[http')).length})</h3>
    <table>
      <thead><tr><th>Name</th><th>Appearances</th><th>Years</th></tr></thead>
      <tbody>
        {unlinkedCandidacies.filter((u: any) => !['Labour','Conservative','Scottish National Party','Unionist','Liberal Unionist','UKIP','Scottish Socialist','Natural Law','Liberal','Liberal Democrat','Green','SNP','Alliance'].includes(u.candidate_name) && !u.candidate_name.startsWith('[http')).map((u: any) => (
          <tr>
            <td>{u.candidate_name}</td>
            <td>{u.n}</td>
            <td style="font-size: 0.8rem;">{u.years}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </details>

  <details>
    <summary><h2 id="no-candidacies">People With No Elections</h2></summary>
    <p class="meta">{noCandidacies.length} people not linked to any election (pre-1707 politicians, MPs without election data in wiki).</p>
    <table>
      <thead><tr><th>Person</th><th>Born</th><th>Died</th></tr></thead>
      <tbody>
        {noCandidacies.map((p: any) => (
          <tr>
            <td><a href={`/person/${p.slug}`}>{p.name}</a></td>
            <td>{p.born_date || ''}</td>
            <td>{p.died_date || ''}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </details>

  {diedBeforeBorn.length > 0 && (
    <details>
      <summary><h2 id="died-before-born">Death date before birth date</h2></summary>
      <table>
        <thead><tr><th>Person</th><th>Born</th><th>Died</th></tr></thead>
        <tbody>
          {diedBeforeBorn.map((p: any) => (
            <tr>
              <td><a href={`/person/${p.slug}`}>{p.name}</a></td>
              <td>{p.born_date}</td>
              <td>{p.died_date}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </details>
  )}

  {longLived.length > 0 && (
    <details>
      <summary><h2 id="long-lived">Unusually long lifespans (95+ years)</h2></summary>
      <table>
        <thead><tr><th>Person</th><th>Born</th><th>Died</th><th>Age</th></tr></thead>
        <tbody>
          {longLived.map((p: any) => (
            <tr>
              <td><a href={`/person/${p.slug}`}>{p.name}</a></td>
              <td>{p.born_date}</td>
              <td>{p.died_date}</td>
              <td>{p.age}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </details>
  )}

  {longCareers.length > 0 && (
    <details>
      <summary><h2 id="long-careers">Very long political careers (40+ years)</h2></summary>
      <p class="meta">May indicate incorrect person linkage (different people with the same name).</p>
      <table>
        <thead><tr><th>Person</th><th>First</th><th>Last</th><th>Span</th><th>Candidacies</th></tr></thead>
        <tbody>
          {longCareers.map((p: any) => (
            <tr>
              <td><a href={`/person/${p.slug}`}>{p.name}</a></td>
              <td>{p.first_election}</td>
              <td>{p.last_election}</td>
              <td>{p.span}y</td>
              <td>{p.num_candidacies}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </details>
  )}

  {voteAnomalies.length > 0 && (
    <details>
      <summary><h2 id="vote-anomalies">Vote count anomalies</h2></summary>
      <p class="meta">Elected candidate received fewer votes than a non-elected. Most are expected in multi-seat elections (e.g. 11 seats, candidate #11 got fewer votes than #12 who lost). Single-seat cases are typically council decisions by petition rather than public votes. Specific notes:</p>
      <ul class="meta" style="margin-bottom: 1rem;">
        <li><strong>1871 LTC</strong>: Peter Garriock (50 votes) rejected office; Laurence Stove was approved by councillors in his place. All others were validly elected.</li>
        <li><strong>1874 LTC</strong>: Transitional election under new Burgh Police Act — 22 elected. Lower-ranked winners had fewer votes than some losers. Normal for large multi-seat.</li>
        <li><strong>Burra 1898</strong>: Decided by council petition, not public vote. Henderson appointed despite Lennie having more petitioners.</li>
        <li><strong>Whiteness 1914</strong>: Council appointed Henderson (22 local petition, 10 council votes) over Sinclair (67 petition, 7 council votes).</li>
        <li><strong>1919 ZCC</strong>: Multi-constituency general election — different wards, different results. Not comparable across wards.</li>
        <li><strong>SIC 2007/2012</strong>: STV multi-seat wards. Winners determined by preference transfers, not first-preference totals.</li>
      </ul>
      <table>
        <thead><tr><th>Election</th><th>Constituency</th><th>Winner (votes)</th><th>Non-winner (votes)</th><th></th></tr></thead>
        <tbody>
          {voteAnomalies.map((v: any) => (
            <tr>
              <td><a href={`/election/${v.election_id}`}>{v.wiki_page_title.replaceAll('_', ' ')}</a></td>
              <td>{v.constituency_name || ''}</td>
              <td>{v.winner_slug ? <a href={`/person/${v.winner_slug}`}>{v.winner_name}</a> : v.winner_name} ({v.winner_votes})</td>
              <td>{v.loser_slug ? <a href={`/person/${v.loser_slug}`}>{v.loser_name}</a> : v.loser_name} ({v.loser_votes})</td>
              <td><a href={`https://shetlandhistory.com/${v.wiki_page_title.replace(/ /g, '_')}`} target="_blank" rel="noopener">wiki</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </details>
  )}

  <details>
    <summary><h2 id="similar-names">Disambiguated name pairs</h2></summary>
    <p class="meta">Most likely source of mislinked candidacies.</p>
    <table>
      <thead><tr><th>Person 1</th><th>Dates</th><th>Person 2</th><th>Dates</th></tr></thead>
      <tbody>
        {similarNames.map((s: any) => (
          <tr>
            <td><a href={`/person/${s.slug1}`}>{s.name1}</a></td>
            <td>{s.born1 ? s.born1.substring(0, 4) : '?'}{s.died1 ? `\u2013${s.died1.substring(0, 4)}` : ''}</td>
            <td><a href={`/person/${s.slug2}`}>{s.name2}</a></td>
            <td>{s.born2 ? s.born2.substring(0, 4) : '?'}{s.died2 ? `\u2013${s.died2.substring(0, 4)}` : ''}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </details>

  {potentialMatches.filter((m: any) => !m.candidate_name.startsWith('[http')).length > 0 && (
    <details>
      <summary><h2 id="potential-matches">Potential matches for unlinked candidacies</h2></summary>
      <table>
        <thead><tr><th>Candidate</th><th>Years</th><th>N</th><th>Possible match</th><th>Dates</th></tr></thead>
        <tbody>
          {potentialMatches.filter((m: any) => !m.candidate_name.startsWith('[http')).map((m: any) => (
            <tr>
              <td>{m.candidate_name}</td>
              <td style="font-size: 0.8rem;">{m.years}</td>
              <td>{m.appearances}</td>
              <td><a href={`/person/${m.slug}`}>{m.person_name}</a></td>
              <td>{m.born_date ? m.born_date.substring(0, 4) : '?'}{m.died_date ? `\u2013${m.died_date.substring(0, 4)}` : ''}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </details>
  )}

  {noBio.length > 0 && (
    <details>
      <summary><h2 id="no-bio">People with no biography text</h2></summary>
      <table>
        <thead><tr><th>Person</th><th>Born</th><th>Died</th><th>Candidacies</th></tr></thead>
        <tbody>
          {noBio.map((p: any) => (
            <tr>
              <td><a href={`/person/${p.slug}`}>{p.name}</a></td>
              <td>{p.born_date || ''}</td>
              <td>{p.died_date || ''}</td>
              <td>{p.candidacies}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </details>
  )}

  {noDateElections.length > 0 && (
    <details>
      <summary><h2 id="no-date">Elections with no date</h2></summary>
      <table>
        <thead><tr><th>Election</th><th>Type</th><th>Council</th></tr></thead>
        <tbody>
          {noDateElections.map((e: any) => (
            <tr>
              <td><a href={`/election/${e.id}`}>{e.wiki_page_title.replaceAll('_', ' ')}</a></td>
              <td>{e.election_type}</td>
              <td>{e.council_name}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </details>
  )}
</Base>

<style>
  .review-nav {
    margin-bottom: 2rem;
    padding: 1rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .danger { color: var(--danger); }
  .warning { color: var(--warning-text); }

  details {
    margin-bottom: 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-surface);
  }

  details summary {
    cursor: pointer;
    padding: 0.75rem 1rem;
    list-style: none;
  }

  details summary::-webkit-details-marker { display: none; }

  details summary h2 {
    display: inline;
    margin: 0;
    border: none;
    padding: 0;
    font-size: 1.1rem;
  }

  details summary::before {
    content: '\25b6';
    display: inline-block;
    margin-right: 0.5rem;
    font-size: 0.8rem;
    transition: transform 0.15s;
  }

  details[open] summary::before {
    transform: rotate(90deg);
  }

  details > :not(summary) {
    padding: 0 1rem 1rem;
  }

  details ul, details ol {
    padding-left: 2.5rem;
  }

  details table {
    margin-top: 0;
  }
</style>
