---
import Base from '../layouts/Base.astro';
import Database from 'better-sqlite3';
import path from 'path';

const db = new Database(path.join(process.cwd(), 'shetland.db'), { readonly: true });

const ltcCouncil = db.prepare("SELECT id FROM councils WHERE slug = 'lerwick-town-council'").get() as any;
const ltcId = ltcCouncil.id;

// Get all LTC elections as snapshot points
const elections = db.prepare(`
  SELECT e.id, e.wiki_page_title, e.election_date, e.election_type
  FROM elections e
  WHERE e.council_id = ? AND e.hidden = 0
  GROUP BY e.wiki_page_title
  ORDER BY e.election_date
`).all(ltcId) as any[];

// Get provosts
const provosts = db.prepare(`
  SELECT person_name, person_id, start_year, end_year
  FROM leadership_roles
  WHERE council_id = ? AND role = 'Provost'
  ORDER BY start_year
`).all(ltcId) as any[];

// Get elected candidates per election (for "new member" highlighting)
const electedByElection = new Map<string, Set<string>>();
for (const e of elections) {
  const cands = db.prepare(`
    SELECT COALESCE(p.name, c.candidate_name) as name
    FROM candidacies c
    JOIN elections e2 ON c.election_id = e2.id
    LEFT JOIN people p ON c.person_id = p.id
    WHERE e2.wiki_page_title = ? AND c.elected = 1 AND e2.hidden = 0
  `).all(e.wiki_page_title) as any[];
  electedByElection.set(e.wiki_page_title, new Set(cands.map((c: any) => c.name)));
}

interface Member {
  name: string;
  slug: string | null;
}

interface Snapshot {
  wikiTitle: string;
  date: string;
  type: string;
  electionId: number;
  members: Member[];
  newMembers: Set<string>;
  provost: string | null;
  provostSlug: string | null;
}

const snapshots: Snapshot[] = [];

for (const election of elections) {
  const edate = election.election_date || '';
  const electionYear = edate.substring(0, 4);

  // Query council_terms for who is serving after this election
  const serving = db.prepare(`
    SELECT ct.person_name as name, p.slug
    FROM council_terms ct
    LEFT JOIN people p ON ct.person_id = p.id
    WHERE ct.council_id = ? AND ct.start_date <= ? AND ct.end_date > ?
    ORDER BY ct.person_name
  `).all(ltcId, edate, edate) as Member[];

  // Deduplicate by name (terms may overlap slightly)
  const seen = new Map<string, Member>();
  for (const m of serving) {
    seen.set(m.name, m);
  }
  const members = Array.from(seen.values());
  members.sort((a, b) => a.name.localeCompare(b.name));

  // New members = those elected at this election
  const electedNames = electedByElection.get(election.wiki_page_title) || new Set<string>();

  // Find provost
  let provost: string | null = null;
  let provostSlug: string | null = null;
  for (const p of provosts) {
    if (electionYear >= p.start_year && electionYear < p.end_year) {
      provost = p.person_name;
      if (p.person_id) {
        const person = db.prepare('SELECT slug FROM people WHERE id = ?').get(p.person_id) as any;
        if (person) provostSlug = person.slug;
      }
      break;
    }
  }

  snapshots.push({
    wikiTitle: election.wiki_page_title,
    date: edate,
    type: election.election_type,
    electionId: election.id,
    members,
    newMembers: electedNames,
    provost,
    provostSlug,
  });
}

function shortDate(d: string): string {
  if (!d) return '?';
  const date = new Date(d);
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${months[date.getMonth()]} ${date.getFullYear()}`;
}

function electionLabel(s: Snapshot): string {
  if (s.type === 'by-election') return shortDate(s.date) + ' (by)';
  return shortDate(s.date);
}

const maxSize = Math.max(...snapshots.map(s => s.members.length));
---
<Base title="Lerwick Town Council Composition (v2)">
  <div class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/council/lerwick-town-council">Lerwick Town Council</a> &rsaquo;
    Council Composition
  </div>

  <h1>Lerwick Town Council Composition</h1>
  <p class="meta">
    The full membership of the council after each election, 1818–1975.
    Driven by council_terms data.
    Scroll horizontally to navigate. Members are sorted alphabetically.
    <span class="new-legend">Highlighted</span> = newly elected at that election.
  </p>

  <div class="timeline-wrapper">
    <table class="timeline-table">
      <thead>
        <tr>
          <th class="row-label sticky-corner"></th>
          {snapshots.map(s => (
            <th class={`election-header ${s.type === 'by-election' ? 'by-election-header' : ''}`}>
              <a href={`/election/${s.electionId}`}>{electionLabel(s)}</a>
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        <tr class="provost-row">
          <td class="row-label"><strong>Provost</strong></td>
          {snapshots.map(s => (
            <td class="provost-cell">
              {s.provost
                ? (s.provostSlug
                    ? <a href={`/person/${s.provostSlug}`}>{s.provost}</a>
                    : s.provost)
                : ''}
            </td>
          ))}
        </tr>
        <tr class="count-row">
          <td class="row-label">Size</td>
          {snapshots.map(s => (
            <td class={`count-cell ${s.members.length > 12 ? 'count-over' : s.members.length < 12 && s.members.length > 0 ? 'count-under' : ''}`}>{s.members.length}</td>
          ))}
        </tr>
        {Array.from({ length: maxSize }, (_, row) => (
          <tr>
            <td class="row-label">{row + 1}</td>
            {snapshots.map(s => {
              const member = s.members[row];
              if (!member) return <td class="empty-cell"></td>;
              const isNew = s.newMembers.has(member.name);
              return (
                <td class={`member-cell ${isNew ? 'new-member' : ''}`}>
                  {member.slug
                    ? <a href={`/person/${member.slug}`}>{member.name}</a>
                    : member.name}
                </td>
              );
            })}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</Base>

<style>
  .new-legend {
    background: var(--success-light);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    font-weight: 600;
    font-size: 0.85rem;
  }

  .timeline-wrapper {
    overflow-x: auto;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    margin: 1.5rem 0;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    max-height: 80vh;
  }

  .timeline-table {
    border-collapse: collapse;
    font-size: 0.76rem;
    white-space: nowrap;
    margin: 0;
    box-shadow: none;
  }

  .timeline-table th,
  .timeline-table td {
    padding: 0.25rem 0.45rem;
    border: 1px solid var(--border-light);
    vertical-align: middle;
  }

  .row-label {
    position: sticky;
    left: 0;
    background: var(--bg-surface);
    z-index: 2;
    font-weight: 600;
    min-width: 3.5rem;
    border-right: 2px solid var(--border) !important;
    text-align: center;
  }

  .sticky-corner {
    z-index: 4;
    position: sticky;
    top: 0;
    left: 0;
  }

  thead th {
    position: sticky;
    top: 0;
    z-index: 3;
  }

  .election-header {
    background: var(--table-header-bg);
    color: var(--table-header-text);
    text-align: center;
    font-size: 0.7rem;
    min-width: 5.5rem;
    font-weight: 500;
  }

  .election-header a { color: var(--table-header-text); }

  .by-election-header {
    background: var(--warning-bg);
    color: var(--warning-text);
  }

  .by-election-header a { color: var(--warning-text); }

  .provost-row td {
    background: var(--accent-light);
    font-weight: 600;
    font-size: 0.73rem;
  }

  .provost-row .row-label {
    background: var(--accent-light);
  }

  .count-row td {
    text-align: center;
    font-weight: 600;
    font-size: 0.7rem;
    color: var(--muted);
  }

  .count-over {
    color: var(--danger) !important;
    font-weight: 700 !important;
  }

  .count-under {
    color: var(--warning-text) !important;
  }

  .member-cell {
    font-size: 0.73rem;
  }

  .new-member {
    background: var(--success-light);
    font-weight: 600;
  }

  .empty-cell {
    background: var(--bg-surface-alt);
  }
</style>
